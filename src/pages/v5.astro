---
import '../styles/global.css';
import { caseStudies } from '../data/caseStudies';

const GA_ID = 'G-4TDGDGK41V';
const featured = caseStudies.filter(cs => cs.featured).slice(0, 4);

const pillars = [
  { num: '01', label: 'DevOps', title: 'Automate everything', desc: 'Terraform, Kubernetes, CI/CD. Your infrastructure defined as code, deployed via GitOps, scaled automatically.', tools: 'Terraform · Kubernetes · ArgoCD · GitHub Actions' },
  { num: '02', label: 'DevSecOps', title: 'Secure by default', desc: 'Image signing, SBOM, vulnerability scanning, secrets rotation. Pass SOC2 and PCI DSS without scrambling.', tools: 'Sigstore · Trivy · Falco · Vault · OPA' },
  { num: '03', label: 'GitOps', title: 'Git as control plane', desc: 'Declarative state, automated reconciliation, drift detection. Every deploy is a PR, every rollback a revert.', tools: 'ArgoCD · Flux · Kustomize · Sealed Secrets' },
  { num: '04', label: 'AIOps', title: 'Intelligent operations', desc: 'AI agents for root cause analysis, automated triage, and expert-level reporting. Minutes, not hours.', tools: 'Claude · Custom Agents · MCP · Prometheus' },
];

const navItems = [
  { label: 'What', href: '#what' },
  { label: 'Proof', href: '#proof' },
  { label: 'How', href: '#how' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, GitOps, AIOps. We build and operate cloud-native platforms." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="v5">

    <!-- NAV -->
    <header id="v5-nav">
      <div class="v5-wrap v5-nav-inner">
        <a href="/v5" class="v5-wordmark">catdev<span>_</span></a>
        <nav class="v5-nav-links">
          {navItems.map(item => (
            <a href={item.href}>{item.label}</a>
          ))}
          <a href="/contact" class="v5-nav-cta">Contact</a>
        </nav>
        <button id="v5-burger" class="v5-burger" aria-label="Menu">
          <span></span><span></span>
        </button>
      </div>
    </header>

    <div id="v5-overlay" class="v5-overlay">
      {navItems.map(item => (
        <a href={item.href} class="v5-overlay-link">{item.label}</a>
      ))}
      <a href="/contact" class="v5-overlay-link v5-overlay-cta">Contact</a>
    </div>

    <!-- HERO -->
    <section class="v5-hero">
      <div class="v5-wrap">
        <div class="v5-hero-grid">
          <div class="v5-hero-left">
            <div class="v5-tag v5-reveal" style="--d:0">consulting</div>
            <h1 class="v5-h1 v5-reveal" style="--d:1">
              Cloud-native<br />platforms,<br /><span>built & operated.</span>
            </h1>
            <p class="v5-hero-p v5-reveal" style="--d:2">
              Senior DevOps engineers who embed with your team.
              Infrastructure as code. Security baked in. Operational from day one.
            </p>
            <div class="v5-hero-btns v5-reveal" style="--d:3">
              <a href="/contact" class="v5-btn">Book review</a>
              <a href="#what" class="v5-link">See capabilities ↓</a>
            </div>
          </div>
          <div class="v5-hero-right v5-reveal" style="--d:2">
            <div class="v5-terminal">
              <div class="v5-terminal-bar"><span></span><span></span><span></span></div>
              <div class="v5-terminal-body">
                <p><span class="v5-t-gray">$</span> terraform apply <span class="v5-t-green">✓</span></p>
                <p><span class="v5-t-gray">$</span> argocd sync <span class="v5-t-green">✓</span></p>
                <p><span class="v5-t-gray">$</span> trivy scan <span class="v5-t-green">0 critical</span></p>
                <p><span class="v5-t-gray">$</span> cosign verify <span class="v5-t-green">✓ signed</span></p>
                <p><span class="v5-t-gray">$</span> kubectl get pods</p>
                <p class="v5-t-dim">  NAME              READY   STATUS</p>
                <p class="v5-t-dim">  api-7b4d8f        <span class="v5-t-green">1/1</span>     Running</p>
                <p class="v5-t-dim">  worker-3c9a1      <span class="v5-t-green">1/1</span>     Running</p>
                <p class="v5-t-dim">  gateway-f82e4     <span class="v5-t-green">1/1</span>     Running</p>
                <p class="v5-t-cursor"><span class="v5-t-gray">$</span> <span class="v5-blink">_</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LOGOS -->
    <section class="v5-logos">
      <div class="v5-wrap">
        <div class="v5-logos-inner v5-reveal" style="--d:0">
          <img src="/logos/callflows_brand_no_claim.webp" alt="Callflows" />
          <img src="/logos/Logo-Color.svg" alt="Growthtastic" />
          <img src="/logos/techgardens.png" alt="techgardens" class="v5-invert" />
          <img src="/logos/theiafiber.png" alt="theiafiber" class="v5-invert" />
        </div>
      </div>
    </section>

    <!-- WHAT -->
    <section id="what" class="v5-section">
      <div class="v5-wrap">
        <h2 class="v5-h2 v5-reveal" style="--d:0">What we do</h2>
        <div class="v5-pillars">
          {pillars.map((p) => (
            <div class="v5-pillar v5-reveal" style={`--d:0`}>
              <div class="v5-pillar-head">
                <span class="v5-pillar-num">{p.num}</span>
                <span class="v5-pillar-label">{p.label}</span>
              </div>
              <h3 class="v5-pillar-title">{p.title}</h3>
              <p class="v5-pillar-desc">{p.desc}</p>
              <p class="v5-pillar-tools">{p.tools}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section id="proof" class="v5-section v5-section-dark">
      <div class="v5-wrap">
        <h2 class="v5-h2 v5-reveal" style="--d:0">Proof, not slides</h2>
        <div class="v5-cases">
          {featured.map((s) => (
            <a href={`/case-studies/${s.slug}`} class="v5-case v5-reveal" style={`--d:0`}>
              <div class="v5-case-top">
                <span class="v5-case-tag">{s.industry}</span>
                <span class="v5-case-type">{s.clientType}</span>
              </div>
              <h3 class="v5-case-title">{s.title}</h3>
              <div class="v5-case-results">
                {s.outcome.slice(0, 2).map(r => (
                  <p class="v5-case-result">↗ {r}</p>
                ))}
              </div>
              <div class="v5-case-stack">
                {s.technologies.slice(0, 5).map(t => (
                  <span>{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
        <div class="v5-cases-link v5-reveal" style="--d:0">
          <a href="/case-studies" class="v5-link">All case studies →</a>
        </div>
      </div>
    </section>

    <!-- HOW -->
    <section id="how" class="v5-section">
      <div class="v5-wrap">
        <h2 class="v5-h2 v5-reveal" style="--d:0">How we work</h2>
        <div class="v5-how-grid">
          <div class="v5-how-left v5-reveal" style="--d:0">
            <div class="v5-how-item">
              <h3>Senior-only</h3>
              <p>10+ years each. The person you interview does the work. No subcontracting.</p>
            </div>
            <div class="v5-how-item">
              <h3>We operate it</h3>
              <p>Not advisory. We deploy, monitor, and respond to incidents. Skin in the game.</p>
            </div>
            <div class="v5-how-item">
              <h3>Week-one velocity</h3>
              <p>No discovery sprints. We embed and ship PRs from day one.</p>
            </div>
            <div class="v5-how-item">
              <h3>Compliance-native</h3>
              <p>SOC2, ISO 27001, PCI DSS. We've passed these for banks and fintechs.</p>
            </div>
          </div>
          <div class="v5-how-right v5-reveal" style="--d:1">
            <div class="v5-engage-card">
              <span class="v5-engage-label">Platform Build</span>
              <span class="v5-engage-scope">6–12 weeks · fixed scope</span>
              <p>Complete delivery platform. Infra, CI/CD, observability. Delivered as code.</p>
            </div>
            <div class="v5-engage-card">
              <span class="v5-engage-label">Managed Ops</span>
              <span class="v5-engage-scope">Monthly retainer</span>
              <p>We run your platform. Monitoring, patching, incident response, compliance.</p>
            </div>
            <div class="v5-engage-card">
              <span class="v5-engage-label">Security Hardening</span>
              <span class="v5-engage-scope">3–6 weeks · assessment</span>
              <p>SBOM, signing, runtime policies, compliance docs. Audit-ready fast.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="v5-cta">
      <div class="v5-wrap v5-reveal" style="--d:0">
        <h2 class="v5-cta-h2">Let's build your platform.</h2>
        <p class="v5-cta-p">Free architecture review. We assess, identify gaps, and show you what production-grade looks like.</p>
        <a href="/contact" class="v5-btn">Book review</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="v5-footer">
      <div class="v5-wrap">
        <div class="v5-footer-top">
          <div class="v5-footer-brand">
            <a href="/v5" class="v5-wordmark">catdev<span>_</span></a>
            <p>Senior DevOps & DevSecOps consulting.</p>
            <div class="v5-footer-addr">
              <strong>CATDEV LLC</strong><br />
              7901 4th St N STE 300<br />
              St. Petersburg, FL 33702<br />
              <a href="mailto:info@catdev.io">info@catdev.io</a>
            </div>
          </div>
          <div class="v5-footer-cols">
            <div>
              <h4>Solutions</h4>
              <a href="/solutions/platform-engineering">Platform Engineering</a>
              <a href="/solutions/devsecops">DevSecOps</a>
              <a href="/solutions/cloud-migration">Cloud Migration</a>
              <a href="/solutions/ai-ops">AI Ops</a>
              <a href="/solutions/managed-ops">Managed Ops</a>
            </div>
            <div>
              <h4>Company</h4>
              <a href="/about">About</a>
              <a href="/approach">How We Work</a>
              <a href="/case-studies">Case Studies</a>
              <a href="/contact">Contact</a>
              <a href="/companies" class="v5-footer-highlight">Our Companies</a>
            </div>
            <div>
              <h4>Legal</h4>
              <a href="/privacy">Privacy Policy</a>
              <a href="/imprint">Imprint</a>
            </div>
          </div>
        </div>
        <div class="v5-footer-bottom">
          <span>&copy; 2026 CATDEV LLC</span>
          <span>A <a href="/companies">catdev LLC</a> company</span>
        </div>
      </div>
    </footer>

    <script>
      // Nav
      const nav = document.getElementById('v5-nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));

      // Burger
      const burger = document.getElementById('v5-burger');
      const overlay = document.getElementById('v5-overlay');
      let menuOpen = false;
      burger?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        burger.classList.toggle('open', menuOpen);
        overlay?.classList.toggle('open', menuOpen);
        document.body.style.overflow = menuOpen ? 'hidden' : '';
      });
      overlay?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        menuOpen = false;
        burger?.classList.remove('open');
        overlay?.classList.remove('open');
        document.body.style.overflow = '';
      }));

      // Reveal
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }});
      }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
      document.querySelectorAll('.v5-reveal').forEach(el => obs.observe(el));

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href'))?.scrollIntoView({ behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      /* ═══════ V5 — Space Grotesk + Terminal ═══════ */
      .v5 {
        --bg: #09090b;
        --bg2: #111113;
        --fg: #e4e4e7;
        --fg2: #a1a1aa;
        --fg3: #52525b;
        --border: rgba(255,255,255,0.06);
        --accent: #00D4FF;
        --green: #22c55e;

        background: var(--bg);
        color: var(--fg);
        font-family: 'Space Grotesk', system-ui, sans-serif;
        font-weight: 300;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .v5-wrap { max-width: 1120px; margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

      /* ── Nav ── */
      #v5-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 1rem 0; transition: all 0.3s; }
      #v5-nav.scrolled { background: rgba(9,9,11,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
      .v5-nav-inner { display: flex; align-items: center; justify-content: space-between; }
      .v5-wordmark { font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 500; color: var(--fg); text-decoration: none; letter-spacing: 0.05em; }
      .v5-wordmark span { color: var(--accent); }
      .v5-nav-links { display: flex; align-items: center; gap: 2rem; }
      .v5-nav-links a { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v5-nav-links a:hover { color: var(--fg); }
      .v5-nav-cta { color: var(--accent) !important; border: 1px solid rgba(0,212,255,0.3); padding: 0.4rem 1rem !important; transition: all 0.2s !important; }
      .v5-nav-cta:hover { background: var(--accent); color: var(--bg) !important; }

      .v5-burger { display: none; background: none; border: none; cursor: pointer; width: 28px; height: 20px; position: relative; }
      .v5-burger span { display: block; width: 100%; height: 1.5px; background: var(--fg); position: absolute; left: 0; transition: all 0.3s; }
      .v5-burger span:first-child { top: 4px; }
      .v5-burger span:last-child { bottom: 4px; }
      .v5-burger.open span:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
      .v5-burger.open span:last-child { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

      .v5-overlay { position: fixed; inset: 0; z-index: 40; background: rgba(9,9,11,0.98); backdrop-filter: blur(24px); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
      .v5-overlay.open { opacity: 1; pointer-events: auto; }
      .v5-overlay-link { font-family: 'Space Grotesk'; font-size: 1.8rem; font-weight: 500; color: var(--fg); text-decoration: none; }
      .v5-overlay-cta { color: var(--accent); font-size: 1.4rem; }

      @media (max-width: 768px) {
        .v5-nav-links { display: none; }
        .v5-burger { display: block; }
      }

      /* ── Hero ── */
      .v5-hero { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 4rem; position: relative; }
      .v5-hero::after { content: ''; position: absolute; top: 20%; right: 0; width: 40%; height: 60%; background: radial-gradient(ellipse at right, rgba(0,212,255,0.03), transparent 70%); pointer-events: none; }
      .v5-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
      .v5-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; display: inline-block; padding: 0.3rem 0.8rem; border: 1px solid rgba(0,212,255,0.2); background: rgba(0,212,255,0.05); }
      .v5-h1 { font-size: clamp(2.4rem, 5vw, 3.8rem); font-weight: 600; line-height: 1.12; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
      .v5-h1 span { color: var(--accent); }
      .v5-hero-p { font-size: 1.05rem; color: var(--fg2); max-width: 440px; margin-bottom: 2rem; }
      .v5-hero-btns { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
      .v5-btn { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; background: var(--accent); color: var(--bg); padding: 0.85rem 1.6rem; text-decoration: none; font-weight: 500; transition: all 0.2s; display: inline-block; }
      .v5-btn:hover { background: var(--fg); transform: translateY(-1px); }
      .v5-link { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v5-link:hover { color: var(--fg); }

      /* Terminal */
      .v5-terminal { background: #0c0c0e; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; line-height: 1.9; }
      .v5-terminal-bar { display: flex; gap: 6px; padding: 12px 16px; border-bottom: 1px solid var(--border); }
      .v5-terminal-bar span { width: 10px; height: 10px; border-radius: 50%; background: var(--fg3); opacity: 0.3; }
      .v5-terminal-body { padding: 16px 20px; color: var(--fg2); }
      .v5-t-gray { color: var(--fg3); }
      .v5-t-green { color: var(--green); }
      .v5-t-dim { color: var(--fg3); }
      .v5-t-cursor { margin-top: 4px; }
      .v5-blink { animation: v5blink 1s step-end infinite; }
      @keyframes v5blink { 50% { opacity: 0; } }

      /* ── Logos ── */
      .v5-logos { padding: 3rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .v5-logos-inner { display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
      .v5-logos-inner img { height: 24px; width: auto; filter: grayscale(1) brightness(1) opacity(0.35); transition: opacity 0.3s; }
      .v5-logos-inner img:hover { filter: grayscale(1) brightness(1.3) opacity(0.7); }
      .v5-invert { filter: brightness(0) invert(1) opacity(0.35) !important; }
      .v5-invert:hover { filter: brightness(0) invert(1) opacity(0.7) !important; }

      /* ── Sections ── */
      .v5-section { padding: 6rem 0; }
      .v5-section-dark { background: var(--bg2); }
      .v5-h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 600; letter-spacing: -0.02em; margin-bottom: 3rem; }

      /* ── Pillars ── */
      .v5-pillars { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--border); }
      .v5-pillar { padding: 2rem; border-right: 1px solid var(--border); }
      .v5-pillar:last-child { border-right: none; }
      .v5-pillar:hover { background: rgba(0,212,255,0.02); }
      .v5-pillar-head { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1rem; }
      .v5-pillar-num { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: var(--fg3); }
      .v5-pillar-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }
      .v5-pillar-title { font-size: 1.1rem; font-weight: 500; margin-bottom: 0.6rem; }
      .v5-pillar-desc { font-size: 0.85rem; color: var(--fg2); line-height: 1.7; margin-bottom: 1rem; }
      .v5-pillar-tools { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: var(--fg3); letter-spacing: 0.03em; }

      /* ── Cases ── */
      .v5-cases { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
      .v5-case { display: block; padding: 2rem; border: 1px solid var(--border); text-decoration: none; color: inherit; transition: all 0.25s; }
      .v5-case:hover { border-color: rgba(0,212,255,0.25); transform: translateY(-2px); }
      .v5-case-top { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.8rem; }
      .v5-case-tag { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); }
      .v5-case-type { font-size: 0.7rem; color: var(--fg3); }
      .v5-case-title { font-size: 1.15rem; font-weight: 500; margin-bottom: 0.8rem; line-height: 1.3; }
      .v5-case-results { margin-bottom: 1rem; }
      .v5-case-result { font-size: 0.8rem; color: var(--fg); padding: 0.15rem 0; }
      .v5-case-stack { display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .v5-case-stack span { font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; color: var(--fg3); padding: 0.25rem 0.5rem; border: 1px solid var(--border); letter-spacing: 0.03em; }
      .v5-cases-link { margin-top: 2rem; }

      /* ── How ── */
      .v5-how-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
      .v5-how-item { padding: 1.5rem 0; border-bottom: 1px solid var(--border); }
      .v5-how-item:last-child { border-bottom: none; }
      .v5-how-item h3 { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.3rem; }
      .v5-how-item p { font-size: 0.85rem; color: var(--fg2); }
      .v5-how-right { display: flex; flex-direction: column; gap: 1rem; }
      .v5-engage-card { padding: 1.5rem; border: 1px solid var(--border); background: var(--bg2); }
