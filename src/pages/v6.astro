---
import '../styles/global.css';

const GA_ID = 'G-4TDGDGK41V';

const pillars = [
  {
    label: 'DevOps',
    title: 'Delivery platforms that ship.',
    body: 'We design, deploy, and operate everything from compute to CI/CD so your team ships daily without touching infrastructure. Declarative, version-controlled, self-healing.',
  },
  {
    label: 'DevSecOps',
    title: 'Security that passes audits.',
    body: 'Supply chain integrity, runtime protection, and continuous vulnerability management built into the platform from day one — not retrofitted before compliance week.',
  },
  {
    label: 'AIOps',
    title: 'AI that replaces toil.',
    body: 'Autonomous failure analysis, intelligent incident response, and AI-driven security testing. Expert-level results in minutes — auditable, explainable, production-proven.',
  },
];

const diffs = [
  { title: 'Senior engineers only', body: 'Every person on your project has 10+ years in production. The person you interview is the person who does the work.' },
  { title: 'We run what we build', body: 'Not advisory-only. We deploy, monitor, patch, and respond to incidents as long-term operational partners.' },
  { title: 'Week-one velocity', body: 'No discovery phases, no slide decks, no steering committees. We embed and ship pull requests from day one.' },
  { title: 'Compliance-native', body: 'SOC2, ISO 27001, PCI DSS, HIPAA. Built and passed for banks, fintechs, and regulated SaaS companies.' },
];

const proof = [
  { client: 'Open-source CI platform', result: '40% faster pipelines, 100% signed images', industry: 'SaaS' },
  { client: 'European banking institution', result: '15 services migrated, zero downtime', industry: 'Finance' },
  { client: 'U.S. bank core exchange', result: 'Zero audit findings, PCI DSS compliant', industry: 'Finance' },
  { client: 'Fiber network operator', result: '95% faster incident reports via AI', industry: 'Telecom' },
];

const navItems = [
  { label: 'Services', href: '#services' },
  { label: 'Why us', href: '#why' },
  { label: 'Proof', href: '#proof' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers who build and operate cloud-native platforms." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting — DevOps · DevSecOps · AIOps</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="v6">

    <!-- NAV -->
    <header id="v6-nav">
      <div class="v6-w v6-nav-row">
        <a href="/v6" class="v6-mark">catdev<span>consulting</span></a>
        <nav class="v6-nav-mid">
          {navItems.map(item => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
        <a href="/contact" class="v6-nav-cta">Get in touch</a>
        <button id="v6-burger" aria-label="Menu"><i></i><i></i></button>
      </div>
    </header>

    <div id="v6-mobile" class="v6-mobile">
      {navItems.map(item => (
        <a href={item.href}>{item.label}</a>
      ))}
      <a href="/contact">Get in touch</a>
    </div>

    <!-- HERO -->
    <section class="v6-hero">
      <div class="v6-w v6-hero-inner">
        <div class="v6-hero-content">
          <h1 class="v6-h1 v6-r" style="--i:0">
            We engineer the platform.<br />
            <em>You ship the product.</em>
          </h1>
          <p class="v6-hero-sub v6-r" style="--i:1">
            Senior DevOps, DevSecOps, and AIOps engineers who embed with your team, build production-grade infrastructure, and stay through operations.
          </p>
          <div class="v6-hero-cta v6-r" style="--i:2">
            <a href="/contact" class="v6-btn">Book architecture review</a>
          </div>
        </div>
        <div class="v6-hero-meta v6-r" style="--i:3">
          <p class="v6-hero-audience">For SaaS teams, banks, AI startups, and regulated industries.</p>
        </div>
      </div>
    </section>

    <!-- LOGOS -->
    <div class="v6-logos">
      <div class="v6-w v6-logos-row v6-r" style="--i:0">
        <img src="/logos/callflows_brand_no_claim.webp" alt="Callflows" />
        <img src="/logos/Logo-Color.svg" alt="Growthtastic" />
        <img src="/logos/techgardens.png" alt="techgardens" class="v6-inv" />
        <img src="/logos/theiafiber.png" alt="theiafiber" class="v6-inv" />
      </div>
    </div>

    <!-- SERVICES -->
    <section id="services" class="v6-section">
      <div class="v6-w">
        <div class="v6-pillars">
          {pillars.map((p, i) => (
            <div class="v6-pillar v6-r" style={`--i:${i}`}>
              <span class="v6-pillar-label">{p.label}</span>
              <h3 class="v6-pillar-title">{p.title}</h3>
              <p class="v6-pillar-body">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- WHY -->
    <section id="why" class="v6-section v6-section-alt">
      <div class="v6-w">
        <h2 class="v6-h2 v6-r" style="--i:0">Engineers, not consultants.</h2>
        <div class="v6-diffs">
          {diffs.map((d, i) => (
            <div class="v6-diff v6-r" style={`--i:${i}`}>
              <h3>{d.title}</h3>
              <p>{d.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROOF -->
    <section id="proof" class="v6-section">
      <div class="v6-w">
        <h2 class="v6-h2 v6-r" style="--i:0">Proof, not promises.</h2>
        <div class="v6-proof-grid">
          {proof.map((p, i) => (
            <div class="v6-proof v6-r" style={`--i:${i}`}>
              <span class="v6-proof-industry">{p.industry}</span>
              <p class="v6-proof-client">{p.client}</p>
              <p class="v6-proof-result">{p.result}</p>
            </div>
          ))}
        </div>
        <div class="v6-proof-link v6-r" style="--i:0">
          <a href="/case-studies" class="v6-link">Read full case studies</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="v6-cta">
      <div class="v6-w v6-cta-inner v6-r" style="--i:0">
        <h2 class="v6-cta-h2">Let's talk about your platform.</h2>
        <p class="v6-cta-sub">Free architecture review. We assess your infrastructure, identify gaps, and show you what production-grade looks like.</p>
        <a href="/contact" class="v6-btn">Book architecture review</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="v6-footer">
      <div class="v6-w">
        <div class="v6-footer-top">
          <div class="v6-footer-brand">
            <a href="/v6" class="v6-mark v6-mark-sm">catdev<span>consulting</span></a>
            <p class="v6-footer-desc">Production-grade platforms. Built, operated, hardened.</p>
            <div class="v6-footer-addr">
              <strong>CATDEV LLC</strong>
              7901 4th St N STE 300, St. Petersburg, FL 33702
              <a href="mailto:info@catdev.io">info@catdev.io</a>
            </div>
          </div>
          <div class="v6-footer-nav">
            <div>
              <h4>Solutions</h4>
              <a href="/solutions/platform-engineering">Platform Engineering</a>
              <a href="/solutions/devsecops">DevSecOps</a>
              <a href="/solutions/cloud-migration">Cloud Migration</a>
              <a href="/solutions/ai-ops">AI Ops</a>
              <a href="/solutions/managed-ops">Managed Ops</a>
            </div>
            <div>
              <h4>Company</h4>
              <a href="/about">About</a>
              <a href="/approach">How We Work</a>
              <a href="/case-studies">Case Studies</a>
              <a href="/contact">Contact</a>
              <a href="/companies" class="v6-hl">Our Companies</a>
            </div>
            <div>
              <h4>Legal</h4>
              <a href="/privacy">Privacy</a>
              <a href="/imprint">Imprint</a>
            </div>
          </div>
        </div>
        <div class="v6-footer-bottom">
          <span>&copy; 2026 CATDEV LLC</span>
          <span>A <a href="/companies">catdev LLC</a> company</span>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('v6-nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));

      const burger = document.getElementById('v6-burger');
      const mobile = document.getElementById('v6-mobile');
      let open = false;
      burger?.addEventListener('click', () => {
        open = !open;
        burger.classList.toggle('open', open);
        mobile?.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
      mobile?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        open = false;
        burger?.classList.remove('open');
        mobile?.classList.remove('open');
        document.body.style.overflow = '';
      }));

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); obs.unobserve(e.target); }});
      }, { threshold: 0.08, rootMargin: '0px 0px -30px 0px' });
      document.querySelectorAll('.v6-r').forEach(el => obs.observe(el));

      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href'))?.scrollIntoView({ behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      .v6 {
        --bg: #0b0b0f;
        --bg2: #101014;
        --fg: #e4e4e7;
        --fg2: #a1a1aa;
        --fg3: #52525b;
        --border: rgba(255,255,255,0.06);
        --accent: #00D4FF;

        background: var(--bg);
        color: var(--fg);
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 300;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .v6-w { max-width: 1060px; margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

      /* NAV */
      #v6-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 0.8rem 0; transition: all 0.3s; }
      #v6-nav.scrolled { background: rgba(11,11,15,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
      .v6-nav-row { display: flex; align-items: center; justify-content: space-between; }
      .v6-mark { font-family: 'Inter'; font-weight: 600; font-size: 0.95rem; color: var(--fg); text-decoration: none; letter-spacing: -0.01em; }
      .v6-mark span { font-weight: 300; color: var(--fg3); margin-left: 0.35rem; }
      .v6-mark-sm { font-size: 0.85rem; }
      .v6-nav-mid { display: flex; gap: 2.5rem; }
      .v6-nav-mid a { font-size: 0.8rem; font-weight: 400; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v6-nav-mid a:hover { color: var(--fg); }
      .v6-nav-cta { font-size: 0.75rem; font-weight: 500; color: var(--accent); border: 1px solid rgba(0,212,255,0.25); padding: 0.45rem 1rem; text-decoration: none; border-radius: 4px; transition: all 0.2s; }
      .v6-nav-cta:hover { background: var(--accent); color: var(--bg); }

      #v6-burger { display: none; background: none; border: none; cursor: pointer; width: 24px; height: 18px; position: relative; }
      #v6-burger i { display: block; width: 100%; height: 1.5px; background: var(--fg); position: absolute; left: 0; transition: all 0.3s; }
      #v6-burger i:first-child { top: 3px; }
      #v6-burger i:last-child { bottom: 3px; }
      #v6-burger.open i:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
      #v6-burger.open i:last-child { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

      .v6-mobile { position: fixed; inset: 0; z-index: 40; background: rgba(11,11,15,0.98); backdrop-filter: blur(20px); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
      .v6-mobile.open { opacity: 1; pointer-events: auto; }
      .v6-mobile a { font-size: 1.6rem; font-weight: 500; color: var(--fg); text-decoration: none; }

      @media (max-width: 768px) {
        .v6-nav-mid, .v6-nav-cta { display: none; }
        #v6-burger { display: block; }
      }

      /* HERO */
      .v6-hero { min-height: 100vh; display: flex; align-items: center; padding: 7rem 0 4rem; position: relative; }
      .v6-hero::after { content: ''; position: absolute; top: 15%; left: 50%; transform: translateX(-50%); width: 800px; height: 600px; background: radial-gradient(ellipse, rgba(0,212,255,0.03), transparent 70%); pointer-events: none; }
      .v6-hero-inner { position: relative; z-index: 1; }
      .v6-hero-content { max-width: 680px; }
      .v6-h1 { font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; font-size: clamp(2.6rem, 5.5vw, 4.2rem); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 1.5rem; }
      .v6-h1 em { font-style: italic; color: var(--accent); }
      .v6-hero-sub { font-size: 1.1rem; color: var(--fg2); max-width: 520px; line-height: 1.75; margin-bottom: 2.5rem; }
      .v6-hero-cta { margin-bottom: 0; }
      .v6-btn { display: inline-flex; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; background: var(--accent); color: var(--bg); padding: 0.85rem 1.8rem; text-decoration: none; transition: all 0.2s; }
      .v6-btn:hover { background: var(--fg); transform: translateY(-1px); }
      .v6-hero-meta { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); }
      .v6-hero-audience { font-size: 0.85rem; color: var(--fg3); }

      /* LOGOS */
      .v6-logos { padding: 2.5rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .v6-logos-row { display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap; }
      .v6-logos-row img { height: 22px; width: auto; filter: grayscale(1) brightness(1) opacity(0.3); transition: opacity 0.3s; }
      .v6-logos-row img:hover { filter: grayscale(1) brightness(1.3) opacity(0.6); }
      .v6-inv { filter: brightness(0) invert(1) opacity(0.3) !important; }
      .v6-inv:hover { filter: brightness(0) invert(1) opacity(0.6) !important; }

      /* SECTIONS */
      .v6-section { padding: 5.5rem 0; }
      .v6-section-alt { background: var(--bg2); }
      .v6-h2 { font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; font-size: clamp(1.8rem, 3.5vw, 2.6rem); line-height: 1.15; margin-bottom: 3rem; }
      .v6-link { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v6-link:hover { color: var(--fg); }

      /* PILLARS */
      .v6-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border: 1px solid var(--border); }
      .v6-pillar { padding: 2.5rem; border-right: 1px solid var(--border); transition: background 0.3s; }
      .v6-pillar:last-child { border-right: none; }
      .v6-pillar:hover { background: rgba(0,212,255,0.015); }
      .v6-pillar-label { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); display: block; margin-bottom: 1rem; }
      .v6-pillar-title { font-family: 'Instrument Serif', Georgia, serif; font-size: 1.4rem; font-weight: 400; margin-bottom: 0.8rem; line-height: 1.25; }
      .v6-pillar-body { font-size: 0.9rem; color: var(--fg2); line-height: 1.75; }

      /* DIFFS */
      .v6-diffs { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid var(--border); }
      .v6-diff { padding: 2rem 2.5rem; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); }
      .v6-diff:nth-child(2n) { border-right: none; }
      .v6-diff:nth-child(n+3) { border-bottom: none; }
      .v6-diff h3 { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.4rem; }
      .v6-diff p { font-size: 0.85rem; color: var(--fg2); line-height: 1.7; }

      /* PROOF */
      .v6-proof-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; border: 1px solid var(--border); }
      .v6-proof { padding: 2rem; border-right: 1px solid var(--border); }
      .v6-proof:last-child { border-right: none; }
      .v6-proof-industry { font-family: 'JetBrains Mono', monospace; font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); }
      .v6-proof-client { font-size: 0.85rem; color: var(--fg); margin: 0.5rem 0 0.8rem; font-weight: 400; }
      .v6-proof-result { font-size: 0.8rem; color: var(--fg2); line-height: 1.6; }
      .v6-proof-link { margin-top: 2rem; }

      /* CTA */
      .v6-cta { padding: 6rem 0; border-top: 1px solid var(--border); }
      .v6-cta-inner { max-width: 540px; }
      .v6-cta-h2 { font-family: 'Instrument Serif', Georgia, serif; font-weight: 400; font-size: clamp(1.8rem, 3.5vw, 2.6rem); line-height: 1.15; margin-bottom: 1rem; }
      .v6-cta-sub { font-size: 1rem; color: var(--fg2); margin-bottom: 2rem; line-height: 1.75; }

      /* FOOTER */
      .v6-footer { border-top: 1px solid var(--border); padding: 3rem 0 1.5rem; }
      .v6-footer-top { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
      .v6-footer-desc { font-size: 0.8rem; color: var(--fg3); margin-top: 0.5rem; }
      .v6-footer-addr { font-size: 0.72rem; color: var(--fg3); line-height: 1.8; margin-top: 1.2rem; }
      .v6-footer-addr strong { color: var(--fg); font-weight: 500; display: block; }
      .v6-footer-addr a { color: var(--accent); text-decoration: none; display: block; margin-top: 0.3rem; }
      .v6-footer-nav { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
      .v6-footer-nav h4 { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg); margin-bottom: 0.8rem; }
      .v6-footer-nav a { display: block; font-size: 0.78rem; color: var(--fg3); text-decoration: none; padding: 0.2rem 0; transition: color 0.2s; }
      .v6-footer-nav a:hover { color: var(--fg); }
      .v6-hl { color: var(--accent) !important; }
      .v6-footer-bottom { display: flex; justify-content: space-between; margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.65rem; color: var(--fg3); }
      .v6-footer-bottom a { color: var(--fg2); text-decoration: none; }

      /* REVEAL */
      .v6-r { opacity: 0; transform: translateY(16px); transition: all 0.55s cubic-bezier(0.16, 1, 0.3, 1); transition-delay: calc(var(--i, 0) * 0.1s); }
      .v6-r.vis { opacity: 1; transform: translateY(0); }

      /* RESPONSIVE */
      @media (max-width: 768px) {
        .v6-pillars { grid-template-columns: 1fr; }
        .v6-pillar { border-right: none; border-bottom: 1px solid var(--border); }
        .v6-pillar:last-child { border-bottom: none; }
        .v6-diffs { grid-template-columns: 1fr; }
        .v6-diff { border-right: none; border-bottom: 1px solid var(--border); }
        .v6-diff:last-child { border-bottom: none; }
        .v6-proof-grid { grid-template-columns: 1fr 1fr; }
        .v6-proof { border-bottom: 1px solid var(--border); }
        .v6-proof:nth-child(2n) { border-right: none; }
        .v6-footer-top { grid-template-columns: 1fr; }
        .v6-footer-nav { grid-template-columns: 1fr 1fr; }
        .v6-footer-bottom { flex-direction: column; gap: 0.3rem; }
      }
      @media (max-width: 480px) {
        .v6-proof-grid { grid-template-columns: 1fr; }
        .v6-proof { border-right: none; }
      }
    </style>

  </body>
</html>
