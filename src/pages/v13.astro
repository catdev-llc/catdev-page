---
import '../styles/global.css';
const GA_ID = 'G-4TDGDGK41V';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="z-body">

    <!-- TICKER -->
    <div class="z-ticker">
      <div class="z-ticker-track">
        <span>DEVOPS</span><span>·</span>
        <span>DEVSECOPS</span><span>·</span>
        <span>AIOPS</span><span>·</span>
        <span>PLATFORM ENGINEERING</span><span>·</span>
        <span>CI/CD</span><span>·</span>
        <span>KUBERNETES</span><span>·</span>
        <span>INFRASTRUCTURE AS CODE</span><span>·</span>
        <span>SUPPLY CHAIN SECURITY</span><span>·</span>
        <span>OBSERVABILITY</span><span>·</span>
        <span>DEVOPS</span><span>·</span>
        <span>DEVSECOPS</span><span>·</span>
        <span>AIOPS</span><span>·</span>
        <span>PLATFORM ENGINEERING</span><span>·</span>
        <span>CI/CD</span><span>·</span>
        <span>KUBERNETES</span><span>·</span>
        <span>INFRASTRUCTURE AS CODE</span><span>·</span>
        <span>SUPPLY CHAIN SECURITY</span><span>·</span>
        <span>OBSERVABILITY</span><span>·</span>
      </div>
    </div>

    <!-- NAV -->
    <header class="z-nav">
      <div class="z-w z-nav-row">
        <a href="/v13" class="z-logo">catdev<sup>®</sup></a>
        <div class="z-nav-center">consulting</div>
        <nav class="z-nav-right">
          <a href="#work">Work</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <!-- HERO -->
    <section class="z-hero">
      <div class="z-w">
        <div class="z-hero-top">
          <span class="z-hero-tag">Infrastructure consultancy</span>
          <span class="z-hero-tag">Est. 2024</span>
        </div>
        <h1 class="z-hero-h">
          We make<br/>
          cloud platforms<br/>
          <span class="z-hero-outline">boring</span><span class="z-lime">.</span>
        </h1>
        <div class="z-hero-bottom">
          <p>Senior engineers who embed with your team, automate the painful parts, and leave you fully independent.</p>
          <a href="#contact" class="z-btn">Start a project ↗</a>
        </div>
      </div>
    </section>

    <!-- MARQUEE DIVIDER -->
    <div class="z-marquee">
      <div class="z-marquee-track">
        <span>EMBED</span><span>★</span>
        <span>BUILD</span><span>★</span>
        <span>HARDEN</span><span>★</span>
        <span>TRANSFER</span><span>★</span>
        <span>EMBED</span><span>★</span>
        <span>BUILD</span><span>★</span>
        <span>HARDEN</span><span>★</span>
        <span>TRANSFER</span><span>★</span>
        <span>EMBED</span><span>★</span>
        <span>BUILD</span><span>★</span>
        <span>HARDEN</span><span>★</span>
        <span>TRANSFER</span><span>★</span>
      </div>
    </div>

    <!-- WORK -->
    <section id="work" class="z-work">
      <div class="z-w">
        <div class="z-work-header">
          <h2 class="z-section-h">What we do</h2>
          <span class="z-section-count">(03)</span>
        </div>

        <div class="z-work-item">
          <div class="z-work-num">01</div>
          <div class="z-work-content">
            <h3>DevOps</h3>
            <p>CI/CD pipelines, container orchestration, infrastructure as code, platform engineering, and observability — designed so your team ships daily without thinking twice.</p>
          </div>
          <div class="z-work-tools">K8s · Terraform · GitHub Actions · ArgoCD</div>
        </div>

        <div class="z-work-item">
          <div class="z-work-num">02</div>
          <div class="z-work-content">
            <h3>DevSecOps</h3>
            <p>Security woven into every pipeline stage. Automated scanning, supply chain hardening, SBOM management, and compliance frameworks that don't become bottlenecks.</p>
          </div>
          <div class="z-work-tools">SAST/DAST · Sigstore · SOC 2 · ISO 27001</div>
        </div>

        <div class="z-work-item">
          <div class="z-work-num">03</div>
          <div class="z-work-content">
            <h3>AIOps</h3>
            <p>Intelligent operations — predictive scaling, automated incident response, anomaly detection, and LLM agents deployed into your infrastructure to reduce toil.</p>
          </div>
          <div class="z-work-tools">ML Pipelines · Smart Alerting · LLM Agents</div>
        </div>
      </div>
    </section>

    <!-- NUMBERS -->
    <section class="z-numbers">
      <div class="z-w z-numbers-row">
        <div class="z-number">
          <span class="z-number-val">40<span class="z-lime">%</span></span>
          <span class="z-number-label">Faster deploys</span>
        </div>
        <div class="z-number">
          <span class="z-number-val">0</span>
          <span class="z-number-label">Security incidents</span>
        </div>
        <div class="z-number">
          <span class="z-number-val">95<span class="z-lime">%</span></span>
          <span class="z-number-label">Pipeline uptime</span>
        </div>
        <div class="z-number">
          <span class="z-number-val">∞</span>
          <span class="z-number-label">Knowledge transfer</span>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="z-about">
      <div class="z-w">
        <div class="z-about-grid">
          <div class="z-about-left">
            <h2 class="z-section-h">How we work</h2>
          </div>
          <div class="z-about-right">
            <div class="z-about-item">
              <span class="z-about-marker">→</span>
              <div>
                <h4>Audit first</h4>
                <p>We map your infrastructure, pipelines, and security posture before proposing anything. Bottlenecks and quick wins documented in a week.</p>
              </div>
            </div>
            <div class="z-about-item">
              <span class="z-about-marker">→</span>
              <div>
                <h4>Embed, don't outsource</h4>
                <p>Our engineers join your standups, your Slack, your on-call. Full context, not a ticket queue from offshore.</p>
              </div>
            </div>
            <div class="z-about-item">
              <span class="z-about-marker">→</span>
              <div>
                <h4>Ship from week one</h4>
                <p>Working infrastructure over slide decks. Iterative delivery with continuous knowledge transfer.</p>
              </div>
            </div>
            <div class="z-about-item">
              <span class="z-about-marker">→</span>
              <div>
                <h4>Leave you independent</h4>
                <p>Runbooks, chaos tests, alerting playbooks. Your team owns everything on day one of handoff. No lock-in.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="contact" class="z-cta">
      <div class="z-w z-cta-inner">
        <h2 class="z-cta-h">Let's make your<br/>infra boring<span class="z-lime">.</span></h2>
        <p>Tell us what's painful. We'll scope it in 48 hours.</p>
        <a href="mailto:hello@catdev.io" class="z-btn z-btn-inv">hello@catdev.io ↗</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="z-footer">
      <div class="z-w z-footer-row">
        <span class="z-footer-copy">© 2026 catdev LLC</span>
        <div class="z-footer-links">
          <a href="/companies">Our Companies</a>
          <a href="https://github.com/catdev-llc" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>

    <style>
      /* ===== BASE ===== */
      .z-body {
        margin: 0;
        padding: 0;
        background: #0c0c0c;
        color: #e4e4e4;
        font-family: 'DM Sans', sans-serif;
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .z-body * { box-sizing: border-box; }

      .z-w {
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 32px;
      }

      .z-lime { color: #a3e635; }

      /* ===== TICKER ===== */
      .z-ticker {
        background: #a3e635;
        color: #0c0c0c;
        overflow: hidden;
        padding: 6px 0;
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 200;
      }

      .z-ticker-track {
        display: flex;
        gap: 24px;
        white-space: nowrap;
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        animation: z-scroll 20s linear infinite;
      }

      @keyframes z-scroll {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
      }

      /* ===== NAV ===== */
      .z-nav {
        position: fixed;
        top: 26px; left: 0; right: 0;
        z-index: 100;
        background: rgba(12,12,12,.85);
        backdrop-filter: blur(16px);
        border-bottom: 1px solid #222;
      }

      .z-nav-row {
        display: flex;
        align-items: center;
        height: 56px;
      }

      .z-logo {
        font-family: 'Space Mono', monospace;
        font-size: 1.1rem;
        font-weight: 700;
        color: #fff;
        text-decoration: none;
      }

      .z-logo sup {
        font-size: 0.5rem;
        color: #a3e635;
        vertical-align: super;
      }

      .z-nav-center {
        margin-left: 12px;
        margin-right: auto;
        font-size: 0.75rem;
        color: #555;
        font-family: 'Space Mono', monospace;
      }

      .z-nav-right {
        display: flex;
        gap: 28px;
      }

      .z-nav-right a {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: #777;
        text-decoration: none;
        transition: color 0.2s;
      }

      .z-nav-right a:hover { color: #a3e635; }

      /* ===== HERO ===== */
      .z-hero {
        padding: 200px 0 120px;
      }

      .z-hero-top {
        display: flex;
        justify-content: space-between;
        margin-bottom: 48px;
      }

      .z-hero-tag {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #555;
      }

      .z-hero-h {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(3rem, 7vw, 6rem);
        font-weight: 700;
        line-height: 1.05;
        margin: 0 0 60px;
        letter-spacing: -0.03em;
      }

      .z-hero-outline {
        color: transparent;
        -webkit-text-stroke: 2px #a3e635;
      }

      .z-hero-bottom {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 40px;
        padding-top: 40px;
        border-top: 1px solid #222;
      }

      .z-hero-bottom p {
        max-width: 480px;
        color: #777;
        font-size: 1rem;
        margin: 0;
        line-height: 1.7;
      }

      .z-btn {
        display: inline-block;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        font-weight: 700;
        background: #a3e635;
        color: #0c0c0c;
        padding: 14px 36px;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.2s;
      }

      .z-btn:hover { background: #bef264; }

      .z-btn-inv {
        background: #fff;
        color: #0c0c0c;
      }

      .z-btn-inv:hover { background: #a3e635; }

      /* ===== MARQUEE ===== */
      .z-marquee {
        overflow: hidden;
        padding: 20px 0;
        border-top: 1px solid #222;
        border-bottom: 1px solid #222;
      }

      .z-marquee-track {
        display: flex;
        gap: 32px;
        white-space: nowrap;
        font-family: 'DM Sans', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: #333;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        animation: z-scroll 15s linear infinite;
      }

      .z-marquee-track span:nth-child(even) {
        color: #a3e635;
      }

      /* ===== WORK ===== */
      .z-work {
        padding: 120px 0;
      }

      .z-work-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 64px;
      }

      .z-section-h {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.6rem;
        font-weight: 700;
        margin: 0;
        letter-spacing: -0.02em;
      }

      .z-section-count {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: #555;
      }

      .z-work-item {
        display: grid;
        grid-template-columns: 60px 1fr 240px;
        gap: 32px;
        padding: 40px 0;
        border-top: 1px solid #222;
        align-items: start;
        transition: border-color 0.3s;
      }

      .z-work-item:last-child {
        border-bottom: 1px solid #222;
      }

      .z-work-item:hover {
        border-color: #a3e635;
      }

      .z-work-num {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: #a3e635;
        padding-top: 4px;
      }

      .z-work-content h3 {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0 0 12px;
        letter-spacing: -0.01em;
      }

      .z-work-content p {
        color: #888;
        font-size: 0.95rem;
        line-height: 1.7;
        margin: 0;
      }

      .z-work-tools {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: #555;
        line-height: 1.8;
        padding-top: 4px;
      }

      /* ===== NUMBERS ===== */
      .z-numbers {
        padding: 80px 0;
        background: #a3e635;
        color: #0c0c0c;
      }

      .z-numbers-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
      }

      .z-number {
        padding: 24px 32px;
        border-left: 2px solid rgba(0,0,0,.1);
      }

      .z-number:first-child { border-left: none; }

      .z-number-val {
        font-family: 'DM Sans', sans-serif;
        font-size: 3.5rem;
        font-weight: 700;
        display: block;
        line-height: 1;
        margin-bottom: 8px;
        letter-spacing: -0.03em;
      }

      .z-number-val .z-lime { color: #0c0c0c; }

      .z-number-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: rgba(0,0,0,.5);
      }

      /* ===== ABOUT ===== */
      .z-about {
        padding: 120px 0;
      }

      .z-about-grid {
        display: grid;
        grid-template-columns: 300px 1fr;
        gap: 80px;
      }

      .z-about-item {
        display: flex;
        gap: 20px;
        padding: 28px 0;
        border-bottom: 1px solid #222;
      }

      .z-about-item:first-child {
        border-top: 1px solid #222;
      }

      .z-about-marker {
        color: #a3e635;
        font-family: 'Space Mono', monospace;
        font-size: 1rem;
        flex-shrink: 0;
        padding-top: 2px;
      }

      .z-about-item h4 {
        font-family: 'DM Sans', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        margin: 0 0 8px;
      }

      .z-about-item p {
        color: #777;
        font-size: 0.9rem;
        line-height: 1.7;
        margin: 0;
      }

      /* ===== CTA ===== */
      .z-cta {
        padding: 140px 0;
        border-top: 1px solid #222;
      }

      .z-cta-inner {
        text-align: center;
      }

      .z-cta-h {
        font-family: 'DM Sans', sans-serif;
        font-size: clamp(2.2rem, 5vw, 4rem);
        font-weight: 700;
        margin: 0 0 16px;
        letter-spacing: -0.03em;
        line-height: 1.1;
      }

      .z-cta-inner > p {
        color: #777;
        font-size: 1rem;
        margin: 0 0 48px;
      }

      /* ===== FOOTER ===== */
      .z-footer {
        border-top: 1px solid #222;
        padding: 24px 0;
      }

      .z-footer-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .z-footer-copy {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: #444;
      }

      .z-footer-links {
        display: flex;
        gap: 24px;
      }

      .z-footer-links a {
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: #444;
        text-decoration: none;
        transition: color 0.2s;
      }

      .z-footer-links a:hover { color: #a3e635; }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 900px) {
        .z-work-item {
          grid-template-columns: 40px 1fr;
          gap: 16px;
        }

        .z-work-tools {
          grid-column: 2;
          padding-top: 0;
        }

        .z-numbers-row {
          grid-template-columns: 1fr 1fr;
        }

        .z-number {
          border-bottom: 2px solid rgba(0,0,0,.1);
        }

        .z-number:nth-child(odd) { border-left: none; }

        .z-about-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .z-nav-right a:nth-child(-n+2) { display: none; }
      }

      @media (max-width: 600px) {
        .z-hero { padding: 160px 0 80px; }
        .z-hero-h { font-size: 2.6rem; }
        .z-hero-outline { -webkit-text-stroke-width: 1.5px; }

        .z-hero-bottom {
          flex-direction: column;
          align-items: start;
        }

        .z-numbers-row { grid-template-columns: 1fr; }
        .z-number { border-left: none; }

        .z-hero-top { flex-direction: column; gap: 4px; }
      }
    </style>

    <script>
      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const target = document.querySelector(a.getAttribute('href'));
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // GA
      if (window.GA_ID) {
        const s = document.createElement('script');
        s.src = `https://www.googletagmanager.com/gtag/js?id=${window.GA_ID}`;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', window.GA_ID);
      }
    </script>

  </body>
</html>
