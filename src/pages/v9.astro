---
import '../styles/global.css';
const GA_ID = 'G-4TDGDGK41V';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="v9">

    <!-- NAV -->
    <header id="v9-nav">
      <div class="v9-w v9-nav-row">
        <a href="/v9" class="v9-wordmark">catdev<span>_</span>consulting</a>
        <nav class="v9-nav-links">
          <a href="#capabilities">Capabilities</a>
          <a href="#track-record">Track record</a>
          <a href="#principles">Principles</a>
        </nav>
        <a href="/contact" class="v9-nav-cta">Start a project →</a>
        <button id="v9-burger" aria-label="Menu"><i></i><i></i></button>
      </div>
    </header>

    <div id="v9-mob" class="v9-mob">
      <a href="#capabilities">Capabilities</a>
      <a href="#track-record">Track record</a>
      <a href="#principles">Principles</a>
      <a href="/contact" class="v9-mob-cta">Start a project →</a>
    </div>

    <!-- HERO -->
    <section class="v9-hero">
      <div class="v9-w">
        <div class="v9-hero-layout">
          <!-- Left column -->
          <div class="v9-hero-left">
            <div class="v9-pill v9-a" style="--d:0">DevOps · DevSecOps · AIOps</div>
            <h1 class="v9-h1 v9-a" style="--d:1">
              We build the infrastructure.<br/>
              You build the future.
            </h1>
            <p class="v9-hero-p v9-a" style="--d:2">
              Senior engineers who embed with your team to design, deploy, secure, and operate cloud-native platforms. No juniors. No hand-offs. No slides.
            </p>
            <a href="/contact" class="v9-btn v9-a" style="--d:3">Book architecture review →</a>
          </div>
          <!-- Right column: live-looking status panel -->
          <div class="v9-hero-right v9-a" style="--d:2">
            <div class="v9-status-panel">
              <div class="v9-status-header">
                <span class="v9-status-dot green"></span>
                <span>Platform Status</span>
              </div>
              <div class="v9-status-row">
                <span>Kubernetes</span>
                <span class="v9-status-ok">Healthy</span>
              </div>
              <div class="v9-status-row">
                <span>CI/CD Pipeline</span>
                <span class="v9-status-ok">42 deploys today</span>
              </div>
              <div class="v9-status-row">
                <span>Security Scan</span>
                <span class="v9-status-ok">0 critical</span>
              </div>
              <div class="v9-status-row">
                <span>Supply Chain</span>
                <span class="v9-status-ok">All signed</span>
              </div>
              <div class="v9-status-row">
                <span>AI Agent</span>
                <span class="v9-status-ok">Monitoring</span>
              </div>
              <div class="v9-status-footer">
                <span>Last check: 12s ago</span>
                <span class="v9-status-dot green sm"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Client strip inline -->
        <div class="v9-hero-clients v9-a" style="--d:4">
          <img src="/logos/callflows_brand_no_claim.webp" alt="Callflows" />
          <img src="/logos/Logo-Color.svg" alt="Growthtastic" />
          <img src="/logos/techgardens.png" alt="techgardens" class="v9-inv" />
          <img src="/logos/theiafiber.png" alt="theiafiber" class="v9-inv" />
        </div>
      </div>
    </section>

    <!-- CAPABILITIES -->
    <section id="capabilities" class="v9-sect">
      <div class="v9-w">
        <h2 class="v9-h2 v9-a" style="--d:0">
          <span class="v9-h2-label">Capabilities</span>
          Three things. Done right.
        </h2>

        <div class="v9-caps">
          <div class="v9-cap v9-a" style="--d:0">
            <div class="v9-cap-top">
              <span class="v9-cap-num">01</span>
              <div class="v9-cap-line"></div>
            </div>
            <h3>DevOps</h3>
            <p class="v9-cap-lead">Delivery platforms that let your team ship daily.</p>
            <p class="v9-cap-body">We codify infrastructure, wire GitOps pipelines, and build self-healing clusters. Everything version-controlled, peer-reviewed, automated. You deploy with a merge, not a prayer.</p>
            <div class="v9-cap-tags">
              <span>Terraform</span><span>Kubernetes</span><span>ArgoCD</span><span>GitHub Actions</span>
            </div>
          </div>

          <div class="v9-cap v9-a" style="--d:1">
            <div class="v9-cap-top">
              <span class="v9-cap-num">02</span>
              <div class="v9-cap-line"></div>
            </div>
            <h3>DevSecOps</h3>
            <p class="v9-cap-lead">Security architecture that passes audits first try.</p>
            <p class="v9-cap-body">Supply chain hardening, image signing, SBOM generation, runtime policies, secrets rotation. Built into the platform from commit one — not patched in before audit week.</p>
            <div class="v9-cap-tags">
              <span>Sigstore</span><span>Trivy</span><span>Falco</span><span>Vault</span>
            </div>
          </div>

          <div class="v9-cap v9-a" style="--d:2">
            <div class="v9-cap-top">
              <span class="v9-cap-num">03</span>
              <div class="v9-cap-line"></div>
            </div>
            <h3>AIOps</h3>
            <p class="v9-cap-lead">AI agents that replace operational toil.</p>
            <p class="v9-cap-body">Autonomous failure analysis, intelligent incident triage, AI-driven penetration testing. Expert-level reports in minutes. Fully auditable, explainable, production-proven.</p>
            <div class="v9-cap-tags">
              <span>Claude</span><span>Custom Agents</span><span>MCP</span><span>MITRE ATT&CK</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TRACK RECORD -->
    <section id="track-record" class="v9-sect v9-sect-dark">
      <div class="v9-w">
        <h2 class="v9-h2 v9-a" style="--d:0">
          <span class="v9-h2-label">Track record</span>
          Outcomes, not promises.
        </h2>

        <div class="v9-records">
          <div class="v9-record v9-a" style="--d:0">
            <div class="v9-record-num">40%</div>
            <div class="v9-record-text">
              <strong>Faster CI pipelines</strong>
              <p>Open-source platform. Rebuilt Drone CI infrastructure, added supply chain security, signed every image.</p>
            </div>
          </div>
          <div class="v9-record v9-a" style="--d:1">
            <div class="v9-record-num">0</div>
            <div class="v9-record-text">
              <strong>Downtime during migration</strong>
              <p>European bank. 15 critical services moved to Azure. PSD2 + GDPR compliant on first review.</p>
            </div>
          </div>
          <div class="v9-record v9-a" style="--d:2">
            <div class="v9-record-num">0</div>
            <div class="v9-record-text">
              <strong>Audit findings</strong>
              <p>U.S. bank core exchange. PCI DSS + FFIEC. Full supply chain security. Deployment in minutes.</p>
            </div>
          </div>
          <div class="v9-record v9-a" style="--d:3">
            <div class="v9-record-num">95%</div>
            <div class="v9-record-text">
              <strong>Faster incident reports</strong>
              <p>Fiber ISP. AI agents replaced manual OTDR analysis. ±15m fault precision. Audit-grade reports.</p>
            </div>
          </div>
        </div>

        <div class="v9-record-link v9-a" style="--d:0">
          <a href="/case-studies">Full case studies →</a>
        </div>
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section id="principles" class="v9-sect">
      <div class="v9-w">
        <h2 class="v9-h2 v9-a" style="--d:0">
          <span class="v9-h2-label">Principles</span>
          How we operate.
        </h2>

        <div class="v9-principles">
          <div class="v9-principle v9-a" style="--d:0">
            <div class="v9-pr-icon">↑</div>
            <h3>Senior-only</h3>
            <p>10+ years production experience. The person you talk to is the person who builds it.</p>
          </div>
          <div class="v9-principle v9-a" style="--d:1">
            <div class="v9-pr-icon">⟳</div>
            <h3>Build & operate</h3>
            <p>Not advisory. We deploy, monitor, patch, and do incident response. Long-term partners.</p>
          </div>
          <div class="v9-principle v9-a" style="--d:2">
            <div class="v9-pr-icon">⚡</div>
            <h3>Week-one delivery</h3>
            <p>No discovery phases. We embed and ship from day one. PRs, not PowerPoints.</p>
          </div>
          <div class="v9-principle v9-a" style="--d:3">
            <div class="v9-pr-icon">✓</div>
            <h3>Compliance-native</h3>
            <p>SOC2, ISO 27001, PCI DSS, HIPAA. Built and passed for banks and regulated SaaS.</p>
          </div>
          <div class="v9-principle v9-a" style="--d:4">
            <div class="v9-pr-icon">☁</div>
            <h3>Any cloud</h3>
            <p>AWS, Azure, GCP, Hetzner, Vultr. We pick what fits your workload, not our partnership.</p>
          </div>
          <div class="v9-principle v9-a" style="--d:5">
            <div class="v9-pr-icon">{`</>`}</div>
            <h3>Everything as code</h3>
            <p>Infrastructure, pipelines, policies, runbooks. Version-controlled, peer-reviewed. Zero ClickOps.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="v9-cta">
      <div class="v9-w v9-cta-inner v9-a" style="--d:0">
        <div class="v9-cta-text">
          <h2>Ready to build?</h2>
          <p>Free architecture review. We'll audit your infrastructure, find the gaps, and map out production-grade.</p>
        </div>
        <a href="/contact" class="v9-btn">Start a project →</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="v9-footer">
      <div class="v9-w">
        <div class="v9-ft-top">
          <div class="v9-ft-brand">
            <a href="/v9" class="v9-wordmark v9-wordmark-sm">catdev<span>_</span>consulting</a>
            <p>Senior DevOps & DevSecOps. Cloud-native platforms.</p>
            <div class="v9-ft-addr">
              <strong>CATDEV LLC</strong>
              7901 4th St N STE 300<br />St. Petersburg, FL 33702
              <a href="mailto:info@catdev.io">info@catdev.io</a>
            </div>
          </div>
          <div class="v9-ft-nav">
            <div>
              <h4>Solutions</h4>
              <a href="/solutions/platform-engineering">Platform Engineering</a>
              <a href="/solutions/devsecops">DevSecOps</a>
              <a href="/solutions/cloud-migration">Cloud Migration</a>
              <a href="/solutions/ai-ops">AI Ops</a>
              <a href="/solutions/managed-ops">Managed Ops</a>
            </div>
            <div>
              <h4>Company</h4>
              <a href="/about">About</a>
              <a href="/approach">How We Work</a>
              <a href="/case-studies">Case Studies</a>
              <a href="/contact">Contact</a>
              <a href="/companies" class="v9-hl">Our Companies</a>
            </div>
            <div>
              <h4>Legal</h4>
              <a href="/privacy">Privacy</a>
              <a href="/imprint">Imprint</a>
            </div>
          </div>
        </div>
        <div class="v9-ft-bot">
          <span>&copy; 2026 CATDEV LLC</span>
          <span>A <a href="/companies">catdev LLC</a> company</span>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('v9-nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));

      const burger = document.getElementById('v9-burger');
      const mob = document.getElementById('v9-mob');
      let open = false;
      burger?.addEventListener('click', () => {
        open = !open;
        burger.classList.toggle('open', open);
        mob?.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
      mob?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        open = false; burger?.classList.remove('open'); mob?.classList.remove('open');
        document.body.style.overflow = '';
      }));

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); obs.unobserve(e.target); }});
      }, { threshold: 0.06, rootMargin: '0px 0px -20px 0px' });
      document.querySelectorAll('.v9-a').forEach(el => obs.observe(el));

      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href'))?.scrollIntoView({ behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      .v9 {
        --bg: #08080c;
        --bg2: #0d0d12;
        --bg3: #111118;
        --fg: #e8e8ee;
        --fg2: #8e8ea0;
        --fg3: #4a4a5c;
        --bdr: rgba(255,255,255,0.06);
        --mint: #34d399;
        --cyan: #00D4FF;
        --blue: #2169B3;

        background: var(--bg);
        color: var(--fg);
        font-family: 'Sora', system-ui, sans-serif;
        font-weight: 300;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .v9-w { max-width: 1100px; margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

      /* NAV */
      #v9-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 0.75rem 0; transition: all 0.3s; }
      #v9-nav.scrolled { background: rgba(8,8,12,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--bdr); }
      .v9-nav-row { display: flex; align-items: center; justify-content: space-between; }
      .v9-wordmark { font-family: 'Fira Code', monospace; font-size: 0.85rem; font-weight: 500; color: var(--fg); text-decoration: none; }
      .v9-wordmark span { color: var(--mint); }
      .v9-wordmark-sm { font-size: 0.78rem; }
      .v9-nav-links { display: flex; gap: 2rem; }
      .v9-nav-links a { font-size: 0.78rem; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v9-nav-links a:hover { color: var(--fg); }
      .v9-nav-cta { font-size: 0.75rem; font-weight: 500; color: var(--bg); background: var(--mint); padding: 0.4rem 1rem; text-decoration: none; border-radius: 4px; transition: all 0.2s; }
      .v9-nav-cta:hover { filter: brightness(1.1); }

      #v9-burger { display: none; background: none; border: none; cursor: pointer; width: 24px; height: 16px; position: relative; }
      #v9-burger i { display: block; width: 100%; height: 1.5px; background: var(--fg); position: absolute; left: 0; transition: all 0.3s; }
      #v9-burger i:first-child { top: 2px; }
      #v9-burger i:last-child { bottom: 2px; }
      #v9-burger.open i:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
      #v9-burger.open i:last-child { bottom: 50%; transform: translateY(50%) rotate(-45deg); }
      .v9-mob { position: fixed; inset: 0; z-index: 40; background: rgba(8,8,12,0.98); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1.5rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
      .v9-mob.open { opacity: 1; pointer-events: auto; }
      .v9-mob a { font-size: 1.4rem; font-weight: 500; color: var(--fg); text-decoration: none; }
      .v9-mob-cta { color: var(--mint) !important; }

      @media (max-width: 768px) {
        .v9-nav-links, .v9-nav-cta { display: none; }
        #v9-burger { display: block; }
      }

      /* HERO */
      .v9-hero { min-height: 100vh; display: flex; align-items: center; padding: 6rem 0 3rem; }
      .v9-hero-layout { display: grid; grid-template-columns: 1fr 380px; gap: 4rem; align-items: center; }
      .v9-pill { display: inline-block; font-family: 'Fira Code', monospace; font-size: 0.65rem; letter-spacing: 0.08em; color: var(--mint); border: 1px solid rgba(52,211,153,0.25); background: rgba(52,211,153,0.05); padding: 0.35rem 0.9rem; border-radius: 100px; margin-bottom: 1.5rem; }
      .v9-h1 { font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 700; line-height: 1.12; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
      .v9-hero-p { font-size: 1rem; color: var(--fg2); max-width: 460px; line-height: 1.75; margin-bottom: 2rem; }
      .v9-btn { display: inline-block; font-family: 'Fira Code', monospace; font-size: 0.72rem; font-weight: 500; background: var(--mint); color: var(--bg); padding: 0.85rem 1.6rem; text-decoration: none; border-radius: 4px; transition: all 0.2s; }
      .v9-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }

      /* Status panel */
      .v9-status-panel { background: var(--bg2); border: 1px solid var(--bdr); border-radius: 10px; overflow: hidden; font-family: 'Fira Code', monospace; font-size: 0.7rem; }
      .v9-status-header { display: flex; align-items: center; gap: 0.5rem; padding: 0.8rem 1.2rem; border-bottom: 1px solid var(--bdr); color: var(--fg2); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; }
      .v9-status-dot { width: 8px; height: 8px; border-radius: 50%; }
      .v9-status-dot.green { background: var(--mint); box-shadow: 0 0 8px rgba(52,211,153,0.4); }
      .v9-status-dot.sm { width: 6px; height: 6px; }
      .v9-status-row { display: flex; justify-content: space-between; padding: 0.65rem 1.2rem; border-bottom: 1px solid var(--bdr); color: var(--fg3); }
      .v9-status-row:last-of-type { border-bottom: none; }
      .v9-status-ok { color: var(--mint); }
      .v9-status-footer { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 1.2rem; border-top: 1px solid var(--bdr); color: var(--fg3); font-size: 0.6rem; }

      .v9-hero-clients { display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--bdr); }
      .v9-hero-clients img { height: 20px; width: auto; filter: grayscale(1) brightness(1) opacity(0.25); transition: opacity 0.3s; }
      .v9-hero-clients img:hover { filter: grayscale(1) brightness(1.3) opacity(0.5); }
      .v9-inv { filter: brightness(0) invert(1) opacity(0.25) !important; }
      .v9-inv:hover { filter: brightness(0) invert(1) opacity(0.5) !important; }

      /* SECTIONS */
      .v9-sect { padding: 5.5rem 0; }
      .v9-sect-dark { background: var(--bg2); }
      .v9-h2 { font-size: clamp(1.7rem, 3vw, 2.4rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.2; margin-bottom: 3rem; }
      .v9-h2-label { display: block; font-family: 'Fira Code', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mint); margin-bottom: 0.6rem; }

      /* CAPABILITIES */
      .v9-caps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
      .v9-cap { padding: 0 2rem; border-left: 1px solid var(--bdr); }
      .v9-cap:first-child { padding-left: 0; border-left: none; }
      .v9-cap-top { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.2rem; }
      .v9-cap-num { font-family: 'Fira Code', monospace; font-size: 0.6rem; color: var(--fg3); }
      .v9-cap-line { flex: 1; height: 1px; background: var(--bdr); }
      .v9-cap h3 { font-size: 1.2rem; font-weight: 600; margin-bottom: 0.5rem; }
      .v9-cap-lead { font-size: 0.88rem; color: var(--mint); margin-bottom: 0.5rem; font-weight: 400; }
      .v9-cap-body { font-size: 0.85rem; color: var(--fg2); line-height: 1.75; margin-bottom: 1.2rem; }
      .v9-cap-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .v9-cap-tags span { font-family: 'Fira Code', monospace; font-size: 0.55rem; color: var(--fg3); padding: 0.25rem 0.5rem; border: 1px solid var(--bdr); border-radius: 3px; }

      /* TRACK RECORD */
      .v9-records { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .v9-record { display: flex; gap: 1.5rem; padding: 1.5rem; border: 1px solid var(--bdr); border-radius: 8px; background: var(--bg3); transition: border-color 0.3s; }
      .v9-record:hover { border-color: rgba(52,211,153,0.2); }
      .v9-record-num { font-size: 2rem; font-weight: 700; color: var(--mint); line-height: 1; min-width: 70px; padding-top: 0.15rem; }
      .v9-record-text strong { font-size: 0.9rem; font-weight: 600; display: block; margin-bottom: 0.3rem; }
      .v9-record-text p { font-size: 0.8rem; color: var(--fg2); line-height: 1.65; }
      .v9-record-link { margin-top: 2rem; }
      .v9-record-link a { font-family: 'Fira Code', monospace; font-size: 0.7rem; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v9-record-link a:hover { color: var(--fg); }

      /* PRINCIPLES */
      .v9-principles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .v9-principle { padding: 1.5rem; border: 1px solid var(--bdr); border-radius: 8px; transition: all 0.3s; }
      .v9-principle:hover { border-color: rgba(52,211,153,0.15); background: rgba(52,211,153,0.02); }
      .v9-pr-icon { font-size: 1.2rem; margin-bottom: 0.8rem; color: var(--mint); }
      .v9-principle h3 { font-size: 0.9rem; font-weight: 600; margin-bottom: 0.3rem; }
