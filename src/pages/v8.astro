          </svg>
          <span>catdev</span>
        </a>
        <nav class="v8-links">
          <a href="#services">Services</a>
          <a href="#results">Results</a>
          <a href="#approach">Approach</a>
          <a href="/contact" class="v8-link-cta">Let's talk</a>
        </nav>
        <button id="v8-burger" aria-label="Menu"><i></i><i></i></button>
      </div>
    </header>

    <div id="v8-mob" class="v8-mob">
      <a href="#services">Services</a>
      <a href="#results">Results</a>
      <a href="#approach">Approach</a>
      <a href="/contact">Let's talk</a>
    </div>

    <!-- HERO -->
    <section class="v8-hero">
      <div class="v8-hero-bg"></div>
      <div class="v8-w v8-hero-content">
        <div class="v8-badge v8-a" style="--d:0">
          <span class="v8-badge-dot"></span>
          Available for new engagements
        </div>
        <h1 class="v8-h1 v8-a" style="--d:1">
          Platform engineering<br />
          for teams that <span class="v8-gradient">ship fast</span>
        </h1>
        <p class="v8-hero-p v8-a" style="--d:2">
          We build, secure, and operate cloud-native infrastructure. Senior engineers only.
          DevOps · DevSecOps · AIOps
        </p>
        <div class="v8-hero-btns v8-a" style="--d:3">
          <a href="/contact" class="v8-btn-fill">Book architecture review</a>
          <a href="#services" class="v8-btn-outline">How we help</a>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <div class="v8-trust">
      <div class="v8-w v8-trust-row v8-a" style="--d:0">
        <span class="v8-trust-label">Trusted by</span>
        <div class="v8-trust-logos">
          <img src="/logos/callflows_brand_no_claim.webp" alt="Callflows" />
          <img src="/logos/Logo-Color.svg" alt="Growthtastic" />
          <img src="/logos/techgardens.png" alt="techgardens" class="v8-inv" />
          <img src="/logos/theiafiber.png" alt="theiafiber" class="v8-inv" />
        </div>
      </div>
    </div>

    <!-- SERVICES -->
    <section id="services" class="v8-sect">
      <div class="v8-w">
        <div class="v8-sect-head v8-a" style="--d:0">
          <span class="v8-label">What we do</span>
          <h2 class="v8-h2">Three disciplines, full lifecycle.</h2>
        </div>
        <div class="v8-cards">
          <div class="v8-card v8-a" style="--d:0">
            <div class="v8-card-icon v8-card-icon-1">
              <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" /></svg>
            </div>
            <h3>DevOps</h3>
            <p class="v8-card-lead">Delivery platforms that scale themselves.</p>
            <p class="v8-card-body">Infrastructure as code, GitOps pipelines, automated everything. Your team ships features; we handle the rest.</p>
          </div>
          <div class="v8-card v8-a" style="--d:1">
            <div class="v8-card-icon v8-card-icon-2">
              <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
            </div>
            <h3>DevSecOps</h3>
            <p class="v8-card-lead">Security that passes audits first time.</p>
            <p class="v8-card-body">Supply chain integrity, runtime protection, continuous vulnerability management. Built in, not bolted on.</p>
          </div>
          <div class="v8-card v8-a" style="--d:2">
            <div class="v8-card-icon v8-card-icon-3">
              <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
            </div>
            <h3>AIOps</h3>
            <p class="v8-card-lead">AI agents that eliminate operational toil.</p>
            <p class="v8-card-body">Autonomous failure analysis, incident response, security testing. Expert-level results in minutes, fully auditable.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section id="results" class="v8-sect v8-sect-dark">
      <div class="v8-w">
        <div class="v8-sect-head v8-a" style="--d:0">
          <span class="v8-label">Results</span>
          <h2 class="v8-h2">What our work delivers.</h2>
        </div>
        <div class="v8-results v8-a" style="--d:0">
          <div class="v8-result">
            <div class="v8-result-bar" style="--w:90%"></div>
            <div class="v8-result-info">
              <span class="v8-result-stat">40% faster</span>
              <span class="v8-result-desc">CI pipeline execution for open-source platform</span>
            </div>
          </div>
          <div class="v8-result">
            <div class="v8-result-bar" style="--w:100%"></div>
            <div class="v8-result-info">
              <span class="v8-result-stat">Zero downtime</span>
              <span class="v8-result-desc">15 banking services migrated to Azure</span>
            </div>
          </div>
          <div class="v8-result">
            <div class="v8-result-bar" style="--w:100%"></div>
            <div class="v8-result-info">
              <span class="v8-result-stat">Zero findings</span>
              <span class="v8-result-desc">PCI DSS + FFIEC audit for U.S. bank pipeline</span>
            </div>
          </div>
          <div class="v8-result">
            <div class="v8-result-bar" style="--w:95%"></div>
            <div class="v8-result-info">
              <span class="v8-result-stat">95% faster</span>
              <span class="v8-result-desc">Incident reports via AI for fiber network operator</span>
            </div>
          </div>
          <div class="v8-result">
            <div class="v8-result-bar" style="--w:60%"></div>
            <div class="v8-result-info">
              <span class="v8-result-stat">60% cost savings</span>
              <span class="v8-result-desc">Vultr Kubernetes vs. AWS EKS for startup</span>
            </div>
          </div>
        </div>
        <div class="v8-results-link v8-a" style="--d:0">
          <a href="/case-studies">Read full case studies →</a>
        </div>
      </div>
    </section>

    <!-- APPROACH -->
    <section id="approach" class="v8-sect">
      <div class="v8-w">
        <div class="v8-sect-head v8-a" style="--d:0">
          <span class="v8-label">How we work</span>
          <h2 class="v8-h2">Engineers, not consultants.</h2>
        </div>
        <div class="v8-approach-grid">
          <div class="v8-approach v8-a" style="--d:0">
            <div class="v8-approach-num">01</div>
            <div>
              <h3>Senior-only</h3>
              <p>10+ years each. The person you interview does the work. No juniors, no subcontracting.</p>
            </div>
          </div>
          <div class="v8-approach v8-a" style="--d:1">
            <div class="v8-approach-num">02</div>
            <div>
              <h3>Build and operate</h3>
              <p>We don't hand off a repo and disappear. We deploy, monitor, patch, and respond to incidents.</p>
            </div>
          </div>
          <div class="v8-approach v8-a" style="--d:2">
            <div class="v8-approach-num">03</div>
            <div>
              <h3>Ship from week one</h3>
              <p>No discovery phases or slide decks. We embed with your team and deliver pull requests immediately.</p>
            </div>
          </div>
          <div class="v8-approach v8-a" style="--d:3">
            <div class="v8-approach-num">04</div>
            <div>
              <h3>Compliance-native</h3>
              <p>SOC2, ISO 27001, PCI DSS, HIPAA. We've built and passed these for banks and fintechs.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="v8-cta-section">
      <div class="v8-cta-bg"></div>
      <div class="v8-w v8-cta-inner v8-a" style="--d:0">
        <h2>Let's build your platform.</h2>
        <p>Free architecture review. We assess your infrastructure, identify gaps, and show you what production-grade looks like.</p>
        <div class="v8-cta-btns">
          <a href="/contact" class="v8-btn-fill v8-btn-white">Book architecture review</a>
          <a href="/solutions" class="v8-btn-outline v8-btn-outline-w">Explore solutions</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="v8-footer">
      <div class="v8-w">
        <div class="v8-ft-top">
          <div class="v8-ft-brand">
            <a href="/v8" class="v8-logo v8-logo-sm">
              <svg class="v8-logo-mark" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <rect width="24" height="24" rx="6" fill="url(#v8g2)" />
                <path d="M7 8.5h4.5a2.5 2.5 0 010 5H7V8.5z" stroke="#fff" stroke-width="1.5" fill="none" />
                <circle cx="16" cy="14.5" r="2" stroke="#fff" stroke-width="1.5" fill="none" />
                <defs><linearGradient id="v8g2" x1="0" y1="0" x2="24" y2="24"><stop stop-color="#2169B3"/><stop offset="1" stop-color="#00D4FF"/></linearGradient></defs>
              </svg>
              <span>catdev</span>
            </a>
            <p>Production-grade platforms. Built, secured, operated.</p>
            <div class="v8-ft-addr">
              <strong>CATDEV LLC</strong>
              7901 4th St N STE 300, St. Petersburg, FL 33702
              <a href="mailto:info@catdev.io">info@catdev.io</a>
            </div>
          </div>
          <div class="v8-ft-nav">
            <div>
              <h4>Solutions</h4>
              <a href="/solutions/platform-engineering">Platform Engineering</a>
              <a href="/solutions/devsecops">DevSecOps</a>
              <a href="/solutions/cloud-migration">Cloud Migration</a>
              <a href="/solutions/ai-ops">AI Ops</a>
              <a href="/solutions/managed-ops">Managed Ops</a>
            </div>
            <div>
              <h4>Company</h4>
              <a href="/about">About</a>
              <a href="/approach">How We Work</a>
              <a href="/case-studies">Case Studies</a>
              <a href="/contact">Contact</a>
              <a href="/companies" class="v8-ft-hl">Our Companies</a>
            </div>
            <div>
              <h4>Legal</h4>
              <a href="/privacy">Privacy</a>
              <a href="/imprint">Imprint</a>
            </div>
          </div>
        </div>
        <div class="v8-ft-bot">
          <span>&copy; 2026 CATDEV LLC</span>
          <span>A <a href="/companies">catdev LLC</a> company</span>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('v8-nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));

      const burger = document.getElementById('v8-burger');
      const mob = document.getElementById('v8-mob');
      let open = false;
      burger?.addEventListener('click', () => {
        open = !open;
        burger.classList.toggle('open', open);
        mob?.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
      mob?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        open = false; burger?.classList.remove('open'); mob?.classList.remove('open');
        document.body.style.overflow = '';
      }));

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); obs.unobserve(e.target); }});
      }, { threshold: 0.06, rootMargin: '0px 0px -20px 0px' });
      document.querySelectorAll('.v8-a').forEach(el => obs.observe(el));

      // Animate result bars
      const barObs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('filled'); barObs.unobserve(e.target); }});
      }, { threshold: 0.3 });
      document.querySelectorAll('.v8-result-bar').forEach(el => barObs.observe(el));

      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href'))?.scrollIntoView({ behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      .v8 {
        --bg: #0a0a0f;
        --bg2: #0e0e14;
        --fg: #eeeef2;
        --fg2: #9696a6;
        --fg3: #4e4e5e;
        --bdr: rgba(255,255,255,0.06);
        --blue: #2169B3;
        --cyan: #00D4FF;
        --purple: #6B4FFF;

        background: var(--bg);
        color: var(--fg);
        font-family: 'Outfit', system-ui, sans-serif;
        font-weight: 300;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .v8-w { max-width: 1080px; margin: 0 auto; padding: 0 clamp(1.25rem, 4vw, 2.5rem); }

      .v8-gradient { background: linear-gradient(135deg, var(--cyan) 0%, var(--blue) 50%, var(--purple) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

      /* NAV */
      #v8-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 0.75rem 0; transition: all 0.3s; }
      #v8-nav.scrolled { background: rgba(10,10,15,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--bdr); }
      .v8-nav-row { display: flex; align-items: center; justify-content: space-between; }
      .v8-logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
      .v8-logo span { font-size: 0.95rem; font-weight: 600; color: var(--fg); }
      .v8-logo-sm .v8-logo-mark { width: 18px; height: 18px; }
      .v8-links { display: flex; align-items: center; gap: 2rem; }
      .v8-links a { font-size: 0.8rem; color: var(--fg3); text-decoration: none; transition: color 0.2s; font-weight: 400; }
      .v8-links a:hover { color: var(--fg); }
      .v8-link-cta { color: var(--cyan) !important; font-weight: 500 !important; }

      #v8-burger { display: none; background: none; border: none; cursor: pointer; width: 24px; height: 16px; position: relative; }
      #v8-burger i { display: block; width: 100%; height: 1.5px; background: var(--fg); position: absolute; left: 0; transition: all 0.3s; }
      #v8-burger i:first-child { top: 2px; }
      #v8-burger i:last-child { bottom: 2px; }
      #v8-burger.open i:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
      #v8-burger.open i:last-child { bottom: 50%; transform: translateY(50%) rotate(-45deg); }
      .v8-mob { position: fixed; inset: 0; z-index: 40; background: rgba(10,10,15,0.98); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
      .v8-mob.open { opacity: 1; pointer-events: auto; }
      .v8-mob a { font-size: 1.5rem; font-weight: 500; color: var(--fg); text-decoration: none; }

      @media (max-width: 768px) {
        .v8-links { display: none; }
        #v8-burger { display: block; }
      }

      /* HERO */
      .v8-hero { min-height: 100vh; display: flex; align-items: center; padding: 7rem 0 5rem; position: relative; overflow: hidden; }
      .v8-hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 70% 30%, rgba(33,105,179,0.08) 0%, transparent 60%), radial-gradient(ellipse at 30% 70%, rgba(107,79,255,0.05) 0%, transparent 60%); }
      .v8-hero-content { position: relative; z-index: 1; max-width: 700px; }
      .v8-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; font-weight: 500; color: var(--fg2); border: 1px solid var(--bdr); border-radius: 100px; padding: 0.4rem 1rem; margin-bottom: 2rem; }
      .v8-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; animation: v8-pulse 2s ease infinite; }
      @keyframes v8-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
      .v8-h1 { font-size: clamp(2.6rem, 5.5vw, 4rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1.5rem; }
      .v8-hero-p { font-size: 1.05rem; color: var(--fg2); max-width: 480px; line-height: 1.75; margin-bottom: 2.5rem; }
      .v8-hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
      .v8-btn-fill { display: inline-flex; align-items: center; font-size: 0.8rem; font-weight: 500; background: var(--cyan); color: var(--bg); padding: 0.8rem 1.6rem; text-decoration: none; border-radius: 6px; transition: all 0.2s; }
      .v8-btn-fill:hover { filter: brightness(1.1); transform: translateY(-1px); }
      .v8-btn-outline { display: inline-flex; align-items: center; font-size: 0.8rem; font-weight: 500; color: var(--fg2); border: 1px solid var(--bdr); padding: 0.8rem 1.6rem; text-decoration: none; border-radius: 6px; transition: all 0.2s; }
      .v8-btn-outline:hover { border-color: var(--fg3); color: var(--fg); }
      .v8-btn-white { background: #fff; color: #111; }
      .v8-btn-outline-w { border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.8); }
      .v8-btn-outline-w:hover { border-color: rgba(255,255,255,0.5); color: #fff; }

      /* TRUST */
      .v8-trust { padding: 2rem 0; border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr); }
      .v8-trust-row { display: flex; align-items: center; gap: 2.5rem; }
      .v8-trust-label { font-size: 0.65rem; font-weight: 500; color: var(--fg3); text-transform: uppercase; letter-spacing: 0.1em; white-space: nowrap; }
      .v8-trust-logos { display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; }
      .v8-trust-logos img { height: 22px; width: auto; filter: grayscale(1) brightness(1) opacity(0.25); transition: opacity 0.3s; }
      .v8-trust-logos img:hover { filter: grayscale(1) brightness(1.3) opacity(0.5); }
      .v8-inv { filter: brightness(0) invert(1) opacity(0.25) !important; }
      .v8-inv:hover { filter: brightness(0) invert(1) opacity(0.5) !important; }

      /* SECTIONS */
      .v8-sect { padding: 5.5rem 0; }
      .v8-sect-dark { background: var(--bg2); }
      .v8-sect-head { margin-bottom: 3rem; }
      .v8-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cyan); display: block; margin-bottom: 0.8rem; }
      .v8-h2 { font-size: clamp(1.7rem, 3vw, 2.4rem); font-weight: 600; letter-spacing: -0.02em; line-height: 1.2; }

      /* CARDS */
      .v8-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .v8-card { padding: 2rem; border: 1px solid var(--bdr); border-radius: 12px; background: rgba(255,255,255,0.015); transition: all 0.3s; }
      .v8-card:hover { border-color: rgba(0,212,255,0.15); background: rgba(255,255,255,0.025); transform: translateY(-2px); }
      .v8-card-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.2rem; color: #fff; }
      .v8-card-icon-1 { background: linear-gradient(135deg, var(--blue), var(--cyan)); }
      .v8-card-icon-2 { background: linear-gradient(135deg, var(--purple), var(--blue)); }
      .v8-card-icon-3 { background: linear-gradient(135deg, var(--cyan), var(--purple)); }
      .v8-card h3 { font-size: 1.15rem; font-weight: 600; margin-bottom: 0.4rem; }
      .v8-card-lead { font-size: 0.88rem; color: var(--cyan); font-weight: 400; margin-bottom: 0.5rem; }
      .v8-card-body { font-size: 0.85rem; color: var(--fg2); line-height: 1.7; }

      /* RESULTS */
      .v8-results { display: flex; flex-direction: column; gap: 1.2rem; }
      .v8-result { display: flex; flex-direction: column; gap: 0.5rem; }
      .v8-result-bar { height: 3px; background: var(--bdr); border-radius: 2px; position: relative; overflow: hidden; }
      .v8-result-bar::after { content: ''; position: absolute; left: 0; top: 0; height: 100%; width: 0; background: linear-gradient(90deg, var(--blue), var(--cyan)); border-radius: 2px; transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1); }
      .v8-result-bar.filled::after { width: var(--w); }
      .v8-result-info { display: flex; align-items: baseline; gap: 1rem; }
      .v8-result-stat { font-size: 1rem; font-weight: 600; white-space: nowrap; }
      .v8-result-desc { font-size: 0.82rem; color: var(--fg2); }
      .v8-results-link { margin-top: 2rem; }
      .v8-results-link a { font-size: 0.8rem; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v8-results-link a:hover { color: var(--fg); }

      /* APPROACH */
      .v8-approach-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
      .v8-approach { display: flex; gap: 1.2rem; padding: 1.5rem; border: 1px solid var(--bdr); border-radius: 10px; transition: border-color 0.3s; }
      .v8-approach:hover { border-color: rgba(0,212,255,0.15); }
      .v8-approach-num { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; color: var(--fg3); padding-top: 0.15rem; }
      .v8-approach h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.3rem; }
      .v8-approach p { font-size: 0.82rem; color: var(--fg2); line-height: 1.65; }

      /* CTA */
      .v8-cta-section { position: relative; padding: 6rem 0; overflow: hidden; }
      .v8-cta-bg { position: absolute; inset: 0; background: linear-gradient(135deg, var(--blue) 0%, #1a3d6b 50%, var(--purple) 100%); }
      .v8-cta-inner { position: relative; z-index: 1; max-width: 540px; }
      .v8-cta-inner h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 1rem; color: #fff; }
      .v8-cta-inner p { font-size: 0.95rem; color: rgba(255,255,255,0.7); margin-bottom: 2rem; line-height: 1.7; }
      .v8-cta-btns { display: flex; gap: 1rem; flex-wrap: wrap; }

      /* FOOTER */
      .v8-footer { border-top: 1px solid var(--bdr); padding: 3rem 0 1.5rem; }
      .v8-ft-top { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
      .v8-ft-brand p { font-size: 0.78rem; color: var(--fg3); margin-top: 0.5rem; }
      .v8-ft-addr { font-size: 0.7rem; color: var(--fg3); line-height: 1.8; margin-top: 1.2rem; }
      .v8-ft-addr strong { color: var(--fg); font-weight: 600; display: block; }
      .v8-ft-addr a { color: var(--cyan); text-decoration: none; display: block; margin-top: 0.3rem; }
      .v8-ft-nav { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
      .v8-ft-nav h4 { font-size: 0.62rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg); margin-bottom: 0.7rem; }
      .v8-ft-nav a { display: block; font-size: 0.76rem; color: var(--fg3); text-decoration: none; padding: 0.2rem 0; transition: color 0.2s; }
      .v8-ft-nav a:hover { color: var(--fg); }
      .v8-ft-hl { color: var(--cyan) !important; }
      .v8-ft-bot { display: flex; justify-content: space-between; margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid var(--bdr); font-size: 0.62rem; color: var(--fg3); }
      .v8-ft-bot a { color: var(--fg2); text-decoration: none; }

      /* ANIM */
      .v8-a { opacity: 0; transform: translateY(16px); transition: all 0.55s cubic-bezier(0.16, 1, 0.3, 1); transition-delay: calc(var(--d, 0) * 0.1s); }
      .v8-a.vis { opacity: 1; transform: translateY(0); }

      @media (max-width: 768px) {
        .v8-cards { grid-template-columns: 1fr; }
        .v8-approach-grid { grid-template-columns: 1fr; }
        .v8-trust-row { flex-direction: column; gap: 1rem; }
        .v8-ft-top { grid-template-columns: 1fr; }
        .v8-ft-nav { grid-template-columns: 1fr 1fr; }
        .v8-ft-bot { flex-direction: column; gap: 0.3rem; }
        .v8-cta-btns { flex-direction: column; }
      }
    </style>

  </body>
