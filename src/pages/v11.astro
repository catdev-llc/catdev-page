---
import '../styles/global.css';
const GA_ID = 'G-4TDGDGK41V';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@400;500;600&family=Source+Code+Pro:wght@400;500&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="s-body">

    <!-- NAV -->
    <header class="s-nav">
      <div class="s-grid s-nav-inner">
        <a href="/v11" class="s-wordmark">CATDEV</a>
        <span class="s-nav-sub">consulting</span>
        <nav class="s-nav-links">
          <a href="#disciplines">Disciplines</a>
          <a href="#process">Process</a>
          <a href="#impact">Impact</a>
          <a href="#contact">Contact</a>
        </nav>
        <button class="s-menu-btn" aria-label="Menu">Menu</button>
      </div>
    </header>

    <!-- HERO -->
    <section class="s-hero">
      <div class="s-grid">
        <div class="s-hero-content">
          <h1 class="s-hero-display">
            INFRASTRUCTURE<br/>
            THAT DISAPPEARS<span class="s-red">.</span>
          </h1>
          <div class="s-hero-meta">
            <div class="s-hero-desc">
              <p>We deploy senior engineers who embed with your team to build, harden, and automate cloud-native platforms. DevOps. DevSecOps. AIOps.</p>
            </div>
            <div class="s-hero-stats">
              <div class="s-stat">
                <span class="s-stat-n">3</span>
                <span class="s-stat-l">Disciplines</span>
              </div>
              <div class="s-stat">
                <span class="s-stat-n">100%</span>
                <span class="s-stat-l">Embedded</span>
              </div>
              <div class="s-stat">
                <span class="s-stat-n">0</span>
                <span class="s-stat-l">Vendor lock-in</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DISCIPLINES -->
    <section id="disciplines" class="s-disciplines">
      <div class="s-grid">
        <div class="s-section-label">
          <span class="s-label-num">01</span>
          <span class="s-label-text">Disciplines</span>
        </div>

        <div class="s-disc-row">
          <div class="s-disc-header">
            <span class="s-disc-title">DevOps</span>
            <span class="s-disc-tag">Platform Engineering</span>
          </div>
          <div class="s-disc-body">
            <p>CI/CD pipelines, infrastructure as code, container orchestration. We design deployment systems your team ships with daily — Kubernetes, Terraform, GitHub Actions, and full observability stacks.</p>
          </div>
        </div>

        <div class="s-disc-row">
          <div class="s-disc-header">
            <span class="s-disc-title">DevSecOps</span>
            <span class="s-disc-tag">Security Engineering</span>
          </div>
          <div class="s-disc-body">
            <p>Security integrated into every pipeline stage. Supply chain hardening, SAST/DAST automation, SBOM management, and compliance frameworks — SOC 2, ISO 27001 — without slowing delivery.</p>
          </div>
        </div>

        <div class="s-disc-row">
          <div class="s-disc-header">
            <span class="s-disc-title">AIOps</span>
            <span class="s-disc-tag">Intelligent Automation</span>
          </div>
          <div class="s-disc-body">
            <p>ML-driven operations for incident response, predictive scaling, and anomaly detection. Automated remediation, intelligent alerting, and LLM agent deployment for infrastructure that learns.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="s-process">
      <div class="s-grid">
        <div class="s-section-label">
          <span class="s-label-num">02</span>
          <span class="s-label-text">Process</span>
        </div>

        <div class="s-process-grid">
          <div class="s-process-item">
            <span class="s-process-n">01</span>
            <h3>Audit</h3>
            <p>We map your infrastructure, pipelines, and security posture. Bottlenecks, risks, and quick wins — documented in a week.</p>
          </div>
          <div class="s-process-item">
            <span class="s-process-n">02</span>
            <h3>Architect</h3>
            <p>Target-state design with your team. Milestones, ownership, and success metrics defined before any code is written.</p>
          </div>
          <div class="s-process-item">
            <span class="s-process-n">03</span>
            <h3>Build</h3>
            <p>Engineers join your squad. Iterative delivery, continuous knowledge transfer, everything documented and owned by your people.</p>
          </div>
          <div class="s-process-item">
            <span class="s-process-n">04</span>
            <h3>Harden</h3>
            <p>Runbooks, alerting, chaos testing, on-call playbooks. We leave your team fully independent on day one of handoff.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- IMPACT -->
    <section id="impact" class="s-impact">
      <div class="s-grid">
        <div class="s-section-label">
          <span class="s-label-num">03</span>
          <span class="s-label-text">Impact</span>
        </div>

        <div class="s-impact-numbers">
          <div class="s-impact-item">
            <span class="s-impact-n">40<span class="s-red">%</span></span>
            <span class="s-impact-l">Faster deployments</span>
          </div>
          <div class="s-impact-item">
            <span class="s-impact-n">0</span>
            <span class="s-impact-l">Security incidents post-engagement</span>
          </div>
          <div class="s-impact-item">
            <span class="s-impact-n">95<span class="s-red">%</span></span>
            <span class="s-impact-l">Pipeline uptime</span>
          </div>
        </div>

        <div class="s-principles">
          <div class="s-principle-row">
            <span class="s-principle-label">Principle</span>
            <span class="s-principle-val">Ship from week one. Working systems over slide decks.</span>
          </div>
          <div class="s-principle-row">
            <span class="s-principle-label">Principle</span>
            <span class="s-principle-val">Embed, never outsource. Your standups, your Slack, your context.</span>
          </div>
          <div class="s-principle-row">
            <span class="s-principle-label">Principle</span>
            <span class="s-principle-val">Automate the repeatable. Eliminate toil systematically.</span>
          </div>
          <div class="s-principle-row">
            <span class="s-principle-label">Principle</span>
            <span class="s-principle-val">Leave you independent. No lock-in, full ownership, always.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="contact" class="s-cta">
      <div class="s-grid">
        <div class="s-cta-content">
          <h2 class="s-cta-display">LET'S BUILD<span class="s-red">.</span></h2>
          <p>Tell us what's slowing your team down. We'll scope it in 48 hours.</p>
          <a href="mailto:hello@catdev.io" class="s-btn">hello@catdev.io →</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="s-footer">
      <div class="s-grid s-footer-inner">
        <div class="s-footer-left">
          <span class="s-wordmark s-wordmark-sm">CATDEV</span>
          <span class="s-footer-copy">© 2026 catdev LLC</span>
        </div>
        <div class="s-footer-right">
          <a href="/companies">Our Companies</a>
          <a href="https://github.com/catdev-llc" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>

    <style>
      /* ===== RESET & BASE ===== */
      .s-body {
        margin: 0;
        padding: 0;
        background: #fafafa;
        color: #1a1a1a;
        font-family: 'Work Sans', sans-serif;
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .s-body * { box-sizing: border-box; }

      .s-grid {
        max-width: 1120px;
        margin: 0 auto;
        padding: 0 32px;
      }

      .s-red { color: #e63946; }

      /* ===== NAV ===== */
      .s-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        background: #fafafa;
        border-bottom: 2px solid #1a1a1a;
      }

      .s-nav-inner {
        display: flex;
        align-items: center;
        height: 60px;
        gap: 12px;
      }

      .s-wordmark {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.6rem;
        color: #1a1a1a;
        text-decoration: none;
        letter-spacing: 0.08em;
        line-height: 1;
      }

      .s-wordmark-sm { font-size: 1.2rem; }

      .s-nav-sub {
        font-family: 'Source Code Pro', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #999;
        margin-right: auto;
      }

      .s-nav-links {
        display: flex;
        gap: 28px;
      }

      .s-nav-links a {
        font-size: 0.85rem;
        font-weight: 500;
        color: #1a1a1a;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        transition: color 0.2s;
      }

      .s-nav-links a:hover { color: #e63946; }

      .s-menu-btn {
        display: none;
        background: none;
        border: 2px solid #1a1a1a;
        padding: 6px 16px;
        font-family: 'Work Sans', sans-serif;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
      }

      /* ===== HERO ===== */
      .s-hero {
        padding: 160px 0 80px;
        border-bottom: 2px solid #1a1a1a;
      }

      .s-hero-display {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(3.5rem, 9vw, 8rem);
        font-weight: 400;
        line-height: 0.95;
        margin: 0 0 60px;
        color: #1a1a1a;
        letter-spacing: 0.02em;
      }

      .s-hero-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        padding-top: 40px;
        border-top: 1px solid #ccc;
      }

      .s-hero-desc p {
        font-size: 1.1rem;
        line-height: 1.7;
        color: #555;
        margin: 0;
      }

      .s-hero-stats {
        display: flex;
        gap: 40px;
        align-items: start;
      }

      .s-stat {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .s-stat-n {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.4rem;
        line-height: 1;
        color: #1a1a1a;
      }

      .s-stat-l {
        font-family: 'Source Code Pro', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #999;
      }

      /* ===== SECTION LABELS ===== */
      .s-section-label {
        display: flex;
        align-items: baseline;
        gap: 16px;
        margin-bottom: 48px;
      }

      .s-label-num {
        font-family: 'Source Code Pro', monospace;
        font-size: 0.75rem;
        color: #e63946;
      }

      .s-label-text {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.4rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #1a1a1a;
      }

      /* ===== DISCIPLINES ===== */
      .s-disciplines {
        padding: 100px 0;
      }

      .s-disc-row {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 40px;
        padding: 40px 0;
        border-top: 1px solid #ddd;
        align-items: start;
      }

      .s-disc-row:last-child {
        border-bottom: 1px solid #ddd;
      }

      .s-disc-header {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .s-disc-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.8rem;
        line-height: 1;
        color: #1a1a1a;
        letter-spacing: 0.02em;
      }

      .s-disc-tag {
        font-family: 'Source Code Pro', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #e63946;
      }

      .s-disc-body p {
        font-size: 1rem;
        line-height: 1.75;
        color: #666;
        margin: 0;
      }

      /* ===== PROCESS ===== */
      .s-process {
        padding: 100px 0;
        background: #1a1a1a;
        color: #fafafa;
      }

      .s-process .s-label-text { color: #fafafa; }
      .s-process .s-label-num { color: #e63946; }

      .s-process-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
      }

      .s-process-item {
        padding: 32px;
        border-left: 1px solid #333;
      }

      .s-process-item:first-child { border-left: none; }

      .s-process-n {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 4rem;
        line-height: 1;
        color: #333;
        display: block;
        margin-bottom: 24px;
        transition: color 0.3s;
      }

      .s-process-item:hover .s-process-n { color: #e63946; }

      .s-process-item h3 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.3rem;
        font-weight: 400;
        letter-spacing: 0.06em;
        margin: 0 0 12px;
        text-transform: uppercase;
      }

      .s-process-item p {
        font-size: 0.9rem;
        line-height: 1.65;
        color: #888;
        margin: 0;
      }

      /* ===== IMPACT ===== */
      .s-impact {
        padding: 100px 0;
      }

      .s-impact-numbers {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        margin-bottom: 80px;
        border-top: 2px solid #1a1a1a;
        border-bottom: 2px solid #1a1a1a;
      }

      .s-impact-item {
        padding: 48px 32px;
        border-right: 1px solid #ddd;
      }

      .s-impact-item:last-child { border-right: none; }

      .s-impact-n {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 5rem;
        line-height: 1;
        display: block;
        margin-bottom: 8px;
        color: #1a1a1a;
      }

      .s-impact-l {
        font-size: 0.85rem;
        color: #888;
        display: block;
      }

      .s-principles {
        display: flex;
        flex-direction: column;
      }

      .s-principle-row {
        display: grid;
        grid-template-columns: 120px 1fr;
        gap: 24px;
        padding: 20px 0;
        border-top: 1px solid #ddd;
        align-items: baseline;
      }

      .s-principle-row:last-child {
        border-bottom: 1px solid #ddd;
      }

      .s-principle-label {
        font-family: 'Source Code Pro', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #e63946;
      }

      .s-principle-val {
        font-size: 0.95rem;
        color: #555;
      }

      /* ===== CTA ===== */
      .s-cta {
        padding: 120px 0;
        background: #1a1a1a;
        color: #fafafa;
      }

      .s-cta-content { max-width: 600px; }

      .s-cta-display {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(3rem, 6vw, 5rem);
        font-weight: 400;
        margin: 0 0 16px;
        letter-spacing: 0.02em;
        line-height: 1;
      }

      .s-cta-content p {
        color: #888;
        font-size: 1.05rem;
        margin: 0 0 40px;
        line-height: 1.6;
      }

      .s-btn {
        display: inline-block;
        border: 2px solid #fafafa;
        color: #fafafa;
        padding: 14px 40px;
        font-family: 'Source Code Pro', monospace;
        font-size: 0.85rem;
        text-decoration: none;
        letter-spacing: 0.06em;
        transition: background 0.2s, color 0.2s;
      }

      .s-btn:hover {
        background: #e63946;
        border-color: #e63946;
        color: #fff;
      }

      /* ===== FOOTER ===== */
      .s-footer {
        border-top: 2px solid #1a1a1a;
        padding: 28px 0;
        background: #fafafa;
      }

      .s-footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .s-footer-left {
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .s-footer-copy {
        font-size: 0.75rem;
        color: #999;
      }

      .s-footer-right {
        display: flex;
        gap: 28px;
      }

      .s-footer-right a {
        color: #888;
        text-decoration: none;
        font-size: 0.8rem;
        transition: color 0.2s;
      }

      .s-footer-right a:hover { color: #1a1a1a; }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 900px) {
        .s-hero-meta {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .s-disc-row {
          grid-template-columns: 1fr;
          gap: 16px;
        }

        .s-process-grid {
          grid-template-columns: 1fr 1fr;
        }

        .s-process-item {
          border-left: none;
          border-bottom: 1px solid #333;
        }

        .s-process-item:nth-child(odd) {
          border-right: 1px solid #333;
        }

        .s-impact-numbers {
          grid-template-columns: 1fr;
        }

        .s-impact-item {
          border-right: none;
          border-bottom: 1px solid #ddd;
        }

        .s-impact-item:last-child { border-bottom: none; }

        .s-nav-links { display: none; }
        .s-menu-btn { display: block; }
      }

      @media (max-width: 600px) {
        .s-hero { padding: 120px 0 60px; }

        .s-hero-display { font-size: 3rem; }

        .s-hero-stats {
          flex-direction: column;
          gap: 24px;
        }

        .s-process-grid { grid-template-columns: 1fr; }

        .s-process-item {
          border-right: none !important;
        }

        .s-principle-row {
          grid-template-columns: 1fr;
          gap: 4px;
        }

        .s-cta-display { font-size: 2.5rem; }
      }
    </style>

    <script>
      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const target = document.querySelector(a.getAttribute('href'));
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // Mobile menu
      const menuBtn = document.querySelector('.s-menu-btn');
      const navLinks = document.querySelector('.s-nav-links');
      if (menuBtn && navLinks) {
        menuBtn.addEventListener('click', () => {
          navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
        });
      }

      // GA
      if (window.GA_ID) {
        const s = document.createElement('script');
        s.src = `https://www.googletagmanager.com/gtag/js?id=${window.GA_ID}`;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', window.GA_ID);
      }
    </script>

  </body>
</html>
