---
import '../styles/global.css';
import { caseStudies } from '../data/caseStudies';

const GA_ID = 'G-4TDGDGK41V';
const featuredStudies = caseStudies.filter(cs => cs.featured).slice(0, 4);

const services = [
  {
    id: 'devops',
    label: 'DevOps',
    headline: 'Infrastructure that scales itself.',
    body: 'We codify your entire infrastructure — servers, clusters, networks, DNS — and wire it into GitOps pipelines that self-heal and self-deploy. No more SSH-ing into boxes. No more snowflake servers.',
    deliverables: [
      'Terraform / OpenTofu modules for multi-cloud',
      'Kubernetes clusters with autoscaling & DR',
      'CI/CD pipelines (GitHub Actions, GitLab CI)',
      'GitOps with ArgoCD or Flux',
      'Observability: Prometheus, Grafana, Loki, Tempo',
    ],
  },
  {
    id: 'devsecops',
    label: 'DevSecOps',
    headline: 'Security as code, not afterthought.',
    body: 'Image signing, SBOM generation, vulnerability scanning, secrets rotation, runtime policies — baked into every pipeline. Pass SOC2, ISO 27001, PCI DSS without scrambling.',
    deliverables: [
      'Supply chain security (Sigstore, Cosign, Rekor)',
      'SBOM & VEX generation per build',
      'Vulnerability management (Trivy, Grype, Snyk)',
      'Secrets management (Vault, AWS SM, Azure KV)',
      'Runtime security (Falco, OPA, Kyverno)',
    ],
  },
  {
    id: 'gitops',
    label: 'GitOps',
    headline: 'Git is the control plane.',
    body: 'Every deployment is a pull request. Every rollback is a revert. Cluster state lives in Git — declarative, auditable, and reconciled automatically. Drift is detected and corrected in seconds.',
    deliverables: [
      'ArgoCD / Flux deployment pipelines',
      'Declarative cluster configuration',
      'Automated drift detection & reconciliation',
      'Multi-environment promotion (dev → staging → prod)',
      'Sealed Secrets & external secrets operators',
    ],
  },
  {
    id: 'aiops',
    label: 'AIOps',
    headline: 'AI agents that replace toil.',
    body: 'Autonomous failure analysis, AI-driven pentesting, intelligent incident response. Our agents produce expert-level technical reports in minutes — auditable, explainable, and production-proven.',
    deliverables: [
      'Custom AI agents for domain-specific operations',
      'Automated root cause analysis',
      'AI-driven penetration testing in CI/CD',
      'Intelligent alerting & anomaly detection',
      'Full audit trails with explainable reasoning',
    ],
  },
];

const stats = [
  { value: '10+', label: 'Years in production' },
  { value: '100%', label: 'Senior engineers' },
  { value: '5+', label: 'Industries served' },
  { value: '0', label: 'Junior contractors' },
];

const engagements = [
  {
    type: 'Platform Build',
    scope: 'Fixed Scope · 6–12 weeks',
    description: 'Complete delivery platform from infrastructure to CI/CD to observability. Terraform, Kubernetes, pipelines, monitoring — delivered as code with operational runbooks.',
  },
  {
    type: 'Managed Operations',
    scope: 'Monthly Retainer',
    description: 'We run your platform. Monitoring, patching, incident response, vulnerability management, compliance documentation. Your team ships features, we handle the rest.',
  },
  {
    type: 'Security Hardening',
    scope: 'Assessment + Upgrade · 3–6 weeks',
    description: 'Supply chain audit, SBOM integration, image signing, runtime policies, compliance documentation. Audit-ready in weeks.',
  },
];

const navItems = [
  { label: 'Services', href: '#services' },
  { label: 'Why Us', href: '#why' },
  { label: 'Work', href: '#work' },
  { label: 'Engage', href: '#engage' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, GitOps, and AIOps engineers. We build and operate cloud-native delivery platforms." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting — DevOps & DevSecOps" />
    <meta property="og:description" content="Senior engineers who build and operate cloud-native platforms. Kubernetes, Terraform, GitOps, supply chain security." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting — DevOps · DevSecOps · GitOps · AIOps</title>
    <script define:vars={{ GA_ID }}>
      window.GA_ID = GA_ID;
    </script>
  </head>

  <body class="overflow-x-hidden">

    <!-- ═══════════════════════════════════════ NAV ═══════════════════════════════════════ -->
    <header id="v3-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="v3-header-bg absolute inset-0 opacity-0 transition-opacity duration-300"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
        <div class="flex items-center justify-between h-16 md:h-20">
          <!-- Logo -->
          <a href="/v3" class="flex items-center gap-3 group">
            <img src="/logo.png" alt="catdev consulting" class="h-9 w-auto" />
            <span class="hidden sm:inline text-steel text-xs font-mono tracking-wider uppercase group-hover:text-white transition-colors">consulting</span>
          </a>

          <!-- Desktop nav -->
          <nav class="hidden md:flex items-center gap-8">
            {navItems.map(item => (
              <a href={item.href} class="text-steel hover:text-white text-sm font-medium transition-colors">{item.label}</a>
            ))}
          </nav>

          <!-- CTA -->
          <a href="/contact" class="hidden md:inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white rounded-lg bg-gradient-to-r from-electric to-purple hover:opacity-90 transition-opacity">
            Get in touch
          </a>

          <!-- Mobile toggle -->
          <button id="v3-mobile-toggle" class="md:hidden w-10 h-10 flex items-center justify-center text-white" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
          </button>
        </div>
      </div>

      <!-- Mobile menu -->
      <div id="v3-mobile-menu" class="fixed inset-0 bg-midnight/98 backdrop-blur-xl z-40 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-all duration-300 md:hidden">
        {navItems.map(item => (
          <a href={item.href} class="v3-mobile-link text-2xl font-bold text-white hover:text-cyan transition-colors">{item.label}</a>
        ))}
        <a href="/contact" class="mt-4 px-8 py-3 text-sm font-semibold text-white rounded-lg bg-gradient-to-r from-electric to-purple">Get in touch</a>
      </div>
    </header>

    <!-- ═══════════════════════════════════════ HERO ═══════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center overflow-hidden">
      <!-- BG -->
      <div class="absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-b from-midnight via-deep-space to-midnight"></div>
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan/30 to-transparent"></div>
        <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-electric/8 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-purple/10 rounded-full blur-[100px]"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 pt-28 pb-20 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Left: copy -->
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-cyan/20 bg-cyan/5 mb-8">
              <span class="w-1.5 h-1.5 rounded-full bg-cyan animate-pulse"></span>
              <span class="text-cyan text-xs font-mono tracking-wider uppercase">Available for Q2 2026</span>
            </div>

            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1] mb-6">
              <span class="text-white">Senior engineers who</span><br />
              <span class="text-gradient">build and operate</span><br />
              <span class="text-white">your platform.</span>
            </h1>

            <p class="text-lg text-steel max-w-lg mb-8 leading-relaxed">
              DevOps, DevSecOps, GitOps, AIOps — we embed with your team, ship from week one, and stay through production. No juniors. No slides. No hand-waving.
            </p>

            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/contact" class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold text-white rounded-lg bg-gradient-to-r from-electric to-purple hover:shadow-lg hover:shadow-electric/25 transition-all">
                Book architecture review
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
              <a href="#services" class="inline-flex items-center justify-center px-7 py-3.5 text-sm font-semibold text-steel border border-white/10 rounded-lg hover:text-white hover:border-white/20 transition-all">
                See what we do
              </a>
            </div>
          </div>

          <!-- Right: stats grid -->
          <div class="hidden lg:grid grid-cols-2 gap-4">
            {stats.map(stat => (
              <div class="p-6 rounded-xl border border-white/5 bg-white/[0.02]">
                <div class="text-3xl font-bold text-white mb-1">{stat.value}</div>
                <div class="text-steel text-sm">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Tech ribbon -->
        <div class="mt-16 pt-8 border-t border-white/5">
          <div class="flex flex-wrap items-center gap-x-8 gap-y-3 text-steel/40 font-mono text-xs tracking-wider uppercase">
            <span>Kubernetes</span>
            <span>Terraform</span>
            <span>ArgoCD</span>
            <span>Sigstore</span>
            <span>Prometheus</span>
            <span>Falco</span>
            <span>Vault</span>
            <span>GitHub Actions</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ SERVICES ═══════════════════════════════════ -->
    <section id="services" class="py-24 md:py-32 relative">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-deep-space/30 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
        <div class="max-w-2xl mb-16 reveal">
          <p class="text-cyan font-mono text-xs uppercase tracking-[0.2em] mb-4">What we do</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
            Four disciplines. One engagement.
          </h2>
          <p class="text-lg text-steel leading-relaxed">
            We don't do one thing. We own the full lifecycle — from infrastructure provisioning to runtime security to autonomous operations.
          </p>
        </div>

        <div class="space-y-6">
          {services.map((svc, i) => (
            <div class="reveal rounded-2xl border border-white/5 bg-white/[0.015] overflow-hidden hover:border-white/10 transition-colors" style={`transition-delay: ${i * 50}ms`}>
              <div class="p-8 md:p-10">
                <div class="grid md:grid-cols-[1fr_300px] gap-8">
                  <!-- Left -->
                  <div>
                    <span class="inline-block px-3 py-1 rounded-full bg-cyan/10 border border-cyan/20 text-cyan text-xs font-mono font-semibold tracking-wider uppercase mb-4">
                      {svc.label}
                    </span>
                    <h3 class="text-2xl font-bold text-white mb-3">{svc.headline}</h3>
                    <p class="text-steel leading-relaxed max-w-xl">{svc.body}</p>
                  </div>

                  <!-- Right: deliverables -->
                  <div class="md:border-l md:border-white/5 md:pl-8">
                    <p class="text-xs text-steel/60 font-mono uppercase tracking-wider mb-3">Deliverables</p>
                    <ul class="space-y-2">
                      {svc.deliverables.map(d => (
                        <li class="flex items-start gap-2 text-sm text-steel">
                          <span class="text-cyan mt-1 flex-shrink-0">—</span>
                          <span>{d}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ WHY US ═══════════════════════════════════ -->
    <section id="why" class="py-24 md:py-32 relative overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-purple/5 rounded-full blur-[100px]"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
        <div class="max-w-2xl mb-16 reveal">
          <p class="text-cyan font-mono text-xs uppercase tracking-[0.2em] mb-4">Why catdev consulting</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
            We've been the engineer on-call at 3 AM.
          </h2>
          <p class="text-lg text-steel leading-relaxed">
            That's why we build platforms differently. No discovery phases. No slide decks. We embed, ship, and operate.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-px bg-white/5 rounded-2xl overflow-hidden reveal">
          <div class="bg-midnight p-8 md:p-10">
            <h3 class="text-lg font-bold text-white mb-2">Senior-only team</h3>
            <p class="text-steel text-sm leading-relaxed">Every engineer has 10+ years in production. No juniors onboarded to your project. No subcontracting. The person you interview is the person who does the work.</p>
          </div>
          <div class="bg-midnight p-8 md:p-10">
            <h3 class="text-lg font-bold text-white mb-2">We run what we build</h3>
            <p class="text-steel text-sm leading-relaxed">We don't hand off a Terraform repo and disappear. We deploy, monitor, patch, and respond to incidents. Skin in the game, not advisory-only.</p>
          </div>
          <div class="bg-midnight p-8 md:p-10">
            <h3 class="text-lg font-bold text-white mb-2">Compliance-native</h3>
            <p class="text-steel text-sm leading-relaxed">SOC2, ISO 27001, PCI DSS, HIPAA, GDPR — we've passed these audits for banks, fintechs, and SaaS companies. Security controls from day one, not bolted on before audit week.</p>
          </div>
          <div class="bg-midnight p-8 md:p-10">
            <h3 class="text-lg font-bold text-white mb-2">Contractor velocity</h3>
            <p class="text-steel text-sm leading-relaxed">We embed with your team and ship from week one. No 6-week discovery phases, no 40-slide assessments, no steering committees. PRs, not PowerPoints.</p>
          </div>
          <div class="bg-midnight p-8 md:p-10">
            <h3 class="text-lg font-bold text-white mb-2">Cloud-agnostic</h3>
            <p class="text-steel text-sm leading-relaxed">AWS, Azure, GCP, Hetzner, Vultr. We pick what fits your workload and budget — not our partnership deal. We've run production on all of them.</p>
          </div>
          <div class="bg-midnight p-8 md:p-10">
            <h3 class="text-lg font-bold text-white mb-2">Everything as code</h3>
            <p class="text-steel text-sm leading-relaxed">Infrastructure, pipelines, policies, runbooks — version-controlled and peer-reviewed. Zero ClickOps. Every change is a commit, every deploy is traceable.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ CASE STUDIES ═══════════════════════════════ -->
    <section id="work" class="py-24 md:py-32 relative">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-deep-space/30 to-transparent"></div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 reveal">
          <div>
            <p class="text-cyan font-mono text-xs uppercase tracking-[0.2em] mb-4">Selected work</p>
            <h2 class="text-3xl md:text-4xl font-bold text-white">
              From startups to banks.
            </h2>
          </div>
          <a href="/case-studies" class="text-steel hover:text-white text-sm font-medium transition-colors mt-4 md:mt-0 inline-flex items-center gap-1">
            All case studies
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {featuredStudies.map((study, i) => (
            <a
              href={`/case-studies/${study.slug}`}
              class="group block rounded-2xl border border-white/5 bg-white/[0.015] p-8 hover:border-cyan/20 transition-all duration-300 reveal"
              style={`transition-delay: ${i * 50}ms`}
            >
              <div class="flex items-center gap-3 mb-4">
                <span class="px-2.5 py-1 bg-cyan/10 border border-cyan/20 rounded-full text-cyan text-xs font-mono font-semibold uppercase tracking-wider">
                  {study.industry}
                </span>
                <span class="text-steel/50 text-xs">{study.clientType}</span>
              </div>

              <h3 class="text-xl font-bold text-white mb-3 group-hover:text-cyan transition-colors">{study.title}</h3>

              <p class="text-steel text-sm leading-relaxed mb-5 line-clamp-2">{study.problem}</p>

              <!-- Outcomes -->
              <div class="space-y-2 mb-5">
                {study.outcome.slice(0, 2).map(result => (
                  <div class="flex items-start gap-2 text-sm">
                    <svg class="w-4 h-4 text-green-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    <span class="text-white/90">{result}</span>
                  </div>
                ))}
              </div>

              <!-- Tech tags -->
              <div class="flex flex-wrap gap-1.5">
                {study.technologies.slice(0, 4).map(tech => (
                  <span class="px-2 py-0.5 bg-white/5 border border-white/10 rounded text-steel text-xs font-mono">{tech}</span>
                ))}
                {study.technologies.length > 4 && (
                  <span class="text-steel/40 text-xs px-1">+{study.technologies.length - 4}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ ENGAGEMENT ═══════════════════════════════ -->
    <section id="engage" class="py-24 md:py-32 relative overflow-hidden">
      <div class="absolute inset-0">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative">
        <div class="text-center mb-16 reveal">
          <p class="text-cyan font-mono text-xs uppercase tracking-[0.2em] mb-4">Engagement models</p>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
            Three ways to work together.
          </h2>
          <p class="text-lg text-steel max-w-xl mx-auto">
            Fixed scope, retainer, or security audit. Pick what fits.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          {engagements.map((eng, i) => (
            <div class="reveal rounded-2xl border border-white/5 bg-white/[0.015] p-8 hover:border-white/10 transition-colors flex flex-col" style={`transition-delay: ${i * 75}ms`}>
              <p class="text-cyan font-mono text-xs font-semibold tracking-wider uppercase mb-1">{eng.type}</p>
              <p class="text-steel/50 text-xs font-mono mb-4">{eng.scope}</p>
              <p class="text-steel text-sm leading-relaxed flex-grow">{eng.description}</p>
              <a href="/contact" class="mt-6 inline-flex items-center text-sm font-semibold text-white hover:text-cyan transition-colors">
                Start conversation
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ CTA ═══════════════════════════════════════ -->
    <section class="py-24 md:py-32 relative">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-electric/5 to-transparent"></div>

      <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center relative reveal">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Ready to stop fighting infrastructure?
        </h2>
        <p class="text-lg text-steel mb-8 max-w-xl mx-auto">
          Book a free architecture review. We'll assess your setup, identify gaps, and show you what production-grade looks like.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/contact" class="inline-flex items-center px-8 py-4 text-sm font-semibold text-white rounded-lg bg-gradient-to-r from-electric to-purple hover:shadow-lg hover:shadow-electric/25 transition-all">
            Book architecture review
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a href="/solutions" class="text-steel hover:text-white text-sm font-medium transition-colors inline-flex items-center gap-1">
            Explore all solutions
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ FOOTER ═══════════════════════════════════ -->
    <footer class="border-t border-white/5">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
          <!-- Brand -->
          <div class="md:col-span-5">
            <a href="/v3" class="flex items-center gap-3 mb-4">
              <img src="/logo.png" alt="catdev consulting" class="h-9 w-auto" />
              <span class="text-steel text-xs font-mono tracking-wider uppercase">consulting</span>
            </a>
            <p class="text-steel text-sm leading-relaxed max-w-sm mb-6">
              Senior DevOps and DevSecOps engineers who build and operate cloud-native delivery platforms.
            </p>
            <div class="text-steel text-xs space-y-1">
              <p class="text-white font-semibold text-sm">CATDEV LLC</p>
              <p>7901 4th St N STE 300</p>
              <p>St. Petersburg, FL 33702</p>
              <a href="mailto:info@catdev.io" class="text-cyan hover:text-white transition-colors inline-block mt-2">info@catdev.io</a>
            </div>
          </div>

          <!-- Solutions -->
          <div class="md:col-span-2">
            <p class="text-white text-xs font-semibold uppercase tracking-wider mb-4">Solutions</p>
            <ul class="space-y-2.5">
              <li><a href="/solutions/platform-engineering" class="text-steel hover:text-white text-sm transition-colors">Platform Engineering</a></li>
              <li><a href="/solutions/devsecops" class="text-steel hover:text-white text-sm transition-colors">DevSecOps</a></li>
