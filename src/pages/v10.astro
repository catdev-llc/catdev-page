---
import '../styles/global.css';
const GA_ID = 'G-4TDGDGK41V';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="x-body">

    <!-- NAV -->
    <header class="x-nav">
      <div class="x-container x-nav-inner">
        <a href="/v10" class="x-logo">catdev<span class="x-dot">.</span></a>
        <nav class="x-nav-links">
          <a href="#services">Services</a>
          <a href="#method">Method</a>
          <a href="#results">Results</a>
          <a href="#contact" class="x-nav-cta">Start a project</a>
        </nav>
        <button class="x-mobile-toggle" aria-label="Menu">
          <span></span><span></span>
        </button>
      </div>
    </header>

    <!-- HERO -->
    <section class="x-hero">
      <div class="x-container">
        <div class="x-hero-grid">
          <div class="x-hero-left">
            <p class="x-hero-label">Engineering consultancy</p>
            <h1 class="x-hero-headline">
              We build the<br/>
              infrastructure<br/>
              you stop thinking<br/>
              about<span class="x-amber">.</span>
            </h1>
          </div>
          <div class="x-hero-right">
            <p class="x-hero-sub">
              catdev consulting deploys senior DevOps, DevSecOps, and AIOps engineers
              who embed with your team — shipping pipelines, hardening platforms,
              and automating what slows you down.
            </p>
            <div class="x-hero-tags">
              <span>DevOps</span>
              <span>DevSecOps</span>
              <span>AIOps</span>
            </div>
          </div>
        </div>
      </div>
      <div class="x-hero-rule"></div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="x-services">
      <div class="x-container">
        <div class="x-section-header">
          <span class="x-section-num">01</span>
          <h2 class="x-section-title">Services</h2>
        </div>

        <div class="x-services-grid">
          <div class="x-service-card">
            <div class="x-service-top">
              <h3>DevOps</h3>
              <span class="x-service-arrow">&nearr;</span>
            </div>
            <p>CI/CD pipelines, infrastructure as code, container orchestration, and platform engineering. We design systems that let your team ship daily without fear.</p>
            <ul class="x-service-list">
              <li>Kubernetes & Helm</li>
              <li>Terraform / Pulumi</li>
              <li>GitHub Actions / GitLab CI</li>
              <li>Observability stacks</li>
            </ul>
          </div>

          <div class="x-service-card">
            <div class="x-service-top">
              <h3>DevSecOps</h3>
              <span class="x-service-arrow">&nearr;</span>
            </div>
            <p>Security shifted left into every pipeline stage. Automated scanning, policy-as-code, and compliance frameworks that don't slow delivery down.</p>
            <ul class="x-service-list">
              <li>Supply chain security</li>
              <li>SAST / DAST integration</li>
              <li>SBOM & vulnerability mgmt</li>
              <li>SOC 2 / ISO 27001 readiness</li>
            </ul>
          </div>

          <div class="x-service-card">
            <div class="x-service-top">
              <h3>AIOps</h3>
              <span class="x-service-arrow">&nearr;</span>
            </div>
            <p>Intelligent automation for incident response, capacity planning, and anomaly detection. ML-driven operations that learn from your infrastructure.</p>
            <ul class="x-service-list">
              <li>Predictive scaling</li>
              <li>Automated remediation</li>
              <li>AI-powered alerting</li>
              <li>LLM agent deployment</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- METHOD -->
    <section id="method" class="x-method">
      <div class="x-container">
        <div class="x-section-header">
          <span class="x-section-num">02</span>
          <h2 class="x-section-title">Method</h2>
        </div>

        <div class="x-method-grid">
          <div class="x-method-step">
            <span class="x-method-n">A</span>
            <h4>Audit</h4>
            <p>Map your current infrastructure, pipelines, and security posture. Identify bottlenecks, risks, and quick wins.</p>
          </div>
          <div class="x-method-step">
            <span class="x-method-n">B</span>
            <h4>Blueprint</h4>
            <p>Design target architecture with your team. Define milestones, ownership, and success metrics before writing a line of code.</p>
          </div>
          <div class="x-method-step">
            <span class="x-method-n">C</span>
            <h4>Build</h4>
            <p>Engineers embed in your squad. Ship iteratively, transfer knowledge continuously, document everything.</p>
          </div>
          <div class="x-method-step">
            <span class="x-method-n">D</span>
            <h4>Defend</h4>
            <p>Harden what's built. Runbooks, alerting, chaos tests, and on-call playbooks so your team owns it fully.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- RESULTS -->
    <section id="results" class="x-results">
      <div class="x-container">
        <div class="x-section-header">
          <span class="x-section-num">03</span>
          <h2 class="x-section-title">Results</h2>
        </div>

        <div class="x-results-band">
          <div class="x-result">
            <span class="x-result-num">40%</span>
            <span class="x-result-label">faster deployments</span>
          </div>
          <div class="x-result-divider"></div>
          <div class="x-result">
            <span class="x-result-num">0</span>
            <span class="x-result-label">security incidents post-engagement</span>
          </div>
          <div class="x-result-divider"></div>
          <div class="x-result">
            <span class="x-result-num">95%</span>
            <span class="x-result-label">pipeline uptime</span>
          </div>
          <div class="x-result-divider"></div>
          <div class="x-result">
            <span class="x-result-num">100%</span>
            <span class="x-result-label">knowledge transfer</span>
          </div>
        </div>

        <blockquote class="x-quote">
          "catdev engineers embedded with our platform team and rebuilt our entire deployment pipeline in eight weeks. Zero downtime migration, full team ownership on day one."
          <cite>— Engineering Director, Series B SaaS</cite>
        </blockquote>
      </div>
    </section>

    <!-- PRINCIPLES -->
    <section class="x-principles">
      <div class="x-container">
        <div class="x-section-header">
          <span class="x-section-num">04</span>
          <h2 class="x-section-title">Principles</h2>
        </div>

        <div class="x-principles-list">
          <div class="x-principle">
            <span class="x-principle-key">01</span>
            <div>
              <h4>Ship, don't theorise</h4>
              <p>Working infrastructure beats slide decks. We deliver running systems from week one.</p>
            </div>
          </div>
          <div class="x-principle">
            <span class="x-principle-key">02</span>
            <div>
              <h4>Embed, don't outsource</h4>
              <p>Our engineers join your standups, your Slack, your on-call rotation. Context is non-negotiable.</p>
            </div>
          </div>
          <div class="x-principle">
            <span class="x-principle-key">03</span>
            <div>
              <h4>Automate the boring</h4>
              <p>If a human is doing it twice, a pipeline should do it forever. We eliminate toil systematically.</p>
            </div>
          </div>
          <div class="x-principle">
            <span class="x-principle-key">04</span>
            <div>
              <h4>Leave you independent</h4>
              <p>Every engagement ends with your team fully owning what we built. No vendor lock-in, ever.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="contact" class="x-cta">
      <div class="x-container">
        <div class="x-cta-block">
          <h2>Ready to ship<span class="x-amber">?</span></h2>
          <p>Tell us what's slowing your team down. We'll scope an engagement in 48 hours.</p>
          <a href="mailto:hello@catdev.io" class="x-btn-primary">hello@catdev.io</a>
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="x-footer">
      <div class="x-container x-footer-inner">
        <div class="x-footer-left">
          <span class="x-logo">catdev<span class="x-dot">.</span></span>
          <span class="x-footer-copy">&copy; 2026 catdev LLC</span>
        </div>
        <div class="x-footer-right">
          <a href="/companies">Our Companies</a>
          <a href="https://github.com/catdev-llc" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </footer>

    <style>
      /* ========== RESET & BASE ========== */
      .x-body {
        margin: 0;
        padding: 0;
        background: #0a0a0a;
        color: #e8e8e8;
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .x-body * { box-sizing: border-box; }

      .x-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* ========== AMBER ACCENT ========== */
      .x-amber { color: #f59e0b; }
      .x-dot { color: #f59e0b; }

      /* ========== NAV ========== */
      .x-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        background: rgba(10,10,10,.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid #1a1a1a;
      }

      .x-nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }

      .x-logo {
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.25rem;
        color: #fff;
        text-decoration: none;
        letter-spacing: -0.02em;
      }

      .x-nav-links {
        display: flex;
        align-items: center;
        gap: 32px;
      }

      .x-nav-links a {
        color: #888;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.2s;
      }

      .x-nav-links a:hover { color: #fff; }

      .x-nav-cta {
        background: #f59e0b !important;
        color: #0a0a0a !important;
        padding: 8px 20px;
        font-weight: 500 !important;
      }

      .x-nav-cta:hover {
        background: #d97706 !important;
      }

      .x-mobile-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
      }

      .x-mobile-toggle span {
        display: block;
        width: 24px;
        height: 2px;
        background: #fff;
        margin: 5px 0;
      }

      /* ========== HERO ========== */
      .x-hero {
        padding: 160px 0 0;
      }

      .x-hero-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 80px;
        align-items: end;
        padding-bottom: 80px;
      }

      .x-hero-label {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #f59e0b;
        margin: 0 0 24px;
      }

      .x-hero-headline {
        font-family: 'Archivo Black', sans-serif;
        font-size: clamp(2.8rem, 5.5vw, 4.5rem);
        font-weight: 400;
        line-height: 1.05;
        margin: 0;
        color: #fff;
        letter-spacing: -0.03em;
      }

      .x-hero-sub {
        color: #999;
        font-size: 1.05rem;
        line-height: 1.7;
        margin: 0 0 32px;
      }

      .x-hero-tags {
        display: flex;
        gap: 12px;
      }

      .x-hero-tags span {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 6px 16px;
        border: 1px solid #333;
        color: #ccc;
      }

      .x-hero-rule {
        height: 1px;
        background: #1a1a1a;
      }

      /* ========== SECTION HEADERS ========== */
      .x-section-header {
        display: flex;
        align-items: baseline;
        gap: 20px;
        margin-bottom: 64px;
        border-bottom: 1px solid #1a1a1a;
        padding-bottom: 20px;
      }

      .x-section-num {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8rem;
        color: #f59e0b;
        letter-spacing: 0.05em;
      }

      .x-section-title {
        font-family: 'Archivo Black', sans-serif;
        font-size: 2rem;
        font-weight: 400;
        margin: 0;
        color: #fff;
        letter-spacing: -0.02em;
      }

      /* ========== SERVICES ========== */
      .x-services {
        padding: 120px 0;
      }

      .x-services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
      }

      .x-service-card {
        padding: 40px;
        border: 1px solid #1a1a1a;
        margin-left: -1px;
        transition: background 0.3s;
      }

      .x-service-card:first-child { margin-left: 0; }

      .x-service-card:hover {
        background: #111;
      }

      .x-service-top {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 20px;
      }

      .x-service-top h3 {
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.4rem;
        font-weight: 400;
        margin: 0;
        color: #fff;
      }

      .x-service-arrow {
        font-size: 1.2rem;
        color: #f59e0b;
      }

      .x-service-card p {
        color: #888;
        font-size: 0.95rem;
        line-height: 1.65;
        margin: 0 0 24px;
      }

      .x-service-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .x-service-list li {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8rem;
        color: #666;
        padding: 8px 0;
        border-top: 1px solid #1a1a1a;
      }

      /* ========== METHOD ========== */
      .x-method {
        padding: 120px 0;
        background: #0e0e0e;
      }

      .x-method-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
      }

      .x-method-step {
        padding: 48px 32px;
        border-left: 1px solid #1a1a1a;
      }

      .x-method-step:first-child { border-left: none; }

      .x-method-n {
        font-family: 'Archivo Black', sans-serif;
        font-size: 3rem;
        color: #1a1a1a;
        line-height: 1;
        display: block;
        margin-bottom: 32px;
        transition: color 0.3s;
      }

      .x-method-step:hover .x-method-n {
        color: #f59e0b;
      }

      .x-method-step h4 {
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.1rem;
        font-weight: 400;
        color: #fff;
        margin: 0 0 12px;
      }

      .x-method-step p {
        color: #777;
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0;
      }

      /* ========== RESULTS ========== */
      .x-results {
        padding: 120px 0;
      }

      .x-results-band {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 64px 0;
        border-top: 1px solid #1a1a1a;
        border-bottom: 1px solid #1a1a1a;
        margin-bottom: 64px;
      }

      .x-result {
        text-align: center;
        flex: 1;
      }

      .x-result-num {
        font-family: 'Archivo Black', sans-serif;
        font-size: 3.5rem;
        color: #f59e0b;
        display: block;
        line-height: 1;
        margin-bottom: 12px;
      }

      .x-result-label {
        font-size: 0.85rem;
        color: #666;
        display: block;
      }

      .x-result-divider {
        width: 1px;
        height: 80px;
        background: #1a1a1a;
      }

      .x-quote {
        font-family: 'Inter', sans-serif;
        font-size: 1.2rem;
        font-style: normal;
        color: #bbb;
        line-height: 1.7;
        margin: 0;
        padding: 0;
        border: none;
        max-width: 720px;
      }

      .x-quote cite {
        display: block;
        margin-top: 20px;
        font-size: 0.85rem;
        color: #555;
        font-style: normal;
        font-family: 'IBM Plex Mono', monospace;
      }

      /* ========== PRINCIPLES ========== */
      .x-principles {
        padding: 120px 0;
        background: #0e0e0e;
      }

      .x-principles-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .x-principle {
        display: flex;
        gap: 40px;
        padding: 32px 0;
        border-bottom: 1px solid #1a1a1a;
        align-items: baseline;
      }

      .x-principle:first-child {
        border-top: 1px solid #1a1a1a;
      }

      .x-principle-key {
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.8rem;
        color: #f59e0b;
        min-width: 32px;
      }

      .x-principle h4 {
        font-family: 'Archivo Black', sans-serif;
        font-size: 1.1rem;
        font-weight: 400;
        color: #fff;
        margin: 0 0 8px;
      }

      .x-principle p {
        color: #777;
        font-size: 0.9rem;
        line-height: 1.6;
        margin: 0;
      }

      /* ========== CTA ========== */
      .x-cta {
        padding: 120px 0;
      }

      .x-cta-block {
        border: 1px solid #1a1a1a;
        padding: 80px;
        text-align: center;
      }

      .x-cta-block h2 {
        font-family: 'Archivo Black', sans-serif;
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 400;
        margin: 0 0 16px;
        color: #fff;
      }

      .x-cta-block p {
        color: #888;
        font-size: 1.05rem;
        margin: 0 0 40px;
      }

      .x-btn-primary {
        display: inline-block;
        background: #f59e0b;
        color: #0a0a0a;
        padding: 16px 48px;
        font-family: 'IBM Plex Mono', monospace;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        letter-spacing: 0.05em;
        transition: background 0.2s;
      }

      .x-btn-primary:hover {
        background: #d97706;
      }

      /* ========== FOOTER ========== */
      .x-footer {
        border-top: 1px solid #1a1a1a;
        padding: 32px 0;
      }

      .x-footer-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .x-footer-left {
        display: flex;
        align-items: center;
        gap: 24px;
      }

      .x-footer-copy {
        font-size: 0.8rem;
        color: #555;
      }

      .x-footer-right {
        display: flex;
        gap: 32px;
      }

      .x-footer-right a {
        color: #555;
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.2s;
      }

      .x-footer-right a:hover { color: #fff; }

      /* ========== RESPONSIVE ========== */
      @media (max-width: 900px) {
        .x-hero-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }

        .x-services-grid {
          grid-template-columns: 1fr;
        }

        .x-service-card {
          margin-left: 0;
          border-top: none;
        }

        .x-service-card:first-child {
          border-top: 1px solid #1a1a1a;
        }

        .x-method-grid {
          grid-template-columns: 1fr 1fr;
          gap: 0;
        }

        .x-method-step {
          border-left: none;
          border-bottom: 1px solid #1a1a1a;
        }

        .x-method-step:nth-child(odd) {
          border-right: 1px solid #1a1a1a;
        }

        .x-results-band {
          flex-direction: column;
          gap: 48px;
        }

        .x-result-divider {
          width: 48px;
          height: 1px;
        }

        .x-cta-block {
          padding: 48px 24px;
        }

        .x-nav-links { display: none; }
        .x-mobile-toggle { display: block; }
      }

      @media (max-width: 600px) {
        .x-method-grid {
          grid-template-columns: 1fr;
        }

        .x-method-step {
          border-right: none !important;
        }

        .x-hero { padding: 120px 0 0; }

        .x-hero-headline {
          font-size: 2.2rem;
        }

        .x-hero-tags {
          flex-wrap: wrap;
        }
      }

      /* ========== SCROLL ANIMATION ========== */
      .x-reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
      }

      .x-reveal.x-visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>

    <script>
      // Scroll reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('x-visible');
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.x-reveal').forEach(el => observer.observe(el));

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const target = document.querySelector(a.getAttribute('href'));
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // Mobile menu
      const toggle = document.querySelector('.x-mobile-toggle');
      const navLinks = document.querySelector('.x-nav-links');
      if (toggle && navLinks) {
        toggle.addEventListener('click', () => {
          navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
        });
      }

      // GA
      if (window.GA_ID) {
        const s = document.createElement('script');
        s.src = `https://www.googletagmanager.com/gtag/js?id=${window.GA_ID}`;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
