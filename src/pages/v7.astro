---
import '../styles/global.css';
const GA_ID = 'G-4TDGDGK41V';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="v7">

    <!-- NAV -->
    <header id="v7-nav">
      <div class="v7-w v7-nav-row">
        <a href="/v7" class="v7-logo">catdev</a>
        <nav class="v7-nav-links">
          <a href="#what">What</a>
          <a href="#work">Work</a>
          <a href="/contact" class="v7-nav-accent">Talk to us</a>
        </nav>
        <button id="v7-burger" aria-label="Menu"><i></i><i></i></button>
      </div>
    </header>

    <div id="v7-mobile" class="v7-mob">
      <a href="#what">What we do</a>
      <a href="#work">Selected work</a>
      <a href="/contact">Talk to us</a>
    </div>

    <!-- HERO -->
    <section class="v7-hero">
      <div class="v7-w">
        <p class="v7-eyebrow v7-a" style="--d:0">catdev consulting</p>
        <h1 class="v7-display v7-a" style="--d:1">
          Your engineers ship product.<br />
          <span>We handle the platform.</span>
        </h1>
        <div class="v7-hero-row v7-a" style="--d:2">
          <p class="v7-hero-sub">DevOps. DevSecOps. AIOps.<br />Senior engineers who embed, build, and operate.</p>
          <a href="/contact" class="v7-cta">Book architecture review →</a>
        </div>
      </div>
    </section>

    <!-- CLIENTS -->
    <div class="v7-strip">
      <div class="v7-w v7-strip-inner v7-a" style="--d:0">
        <img src="/logos/callflows_brand_no_claim.webp" alt="Callflows" />
        <img src="/logos/Logo-Color.svg" alt="Growthtastic" />
        <img src="/logos/techgardens.png" alt="techgardens" class="v7-inv" />
        <img src="/logos/theiafiber.png" alt="theiafiber" class="v7-inv" />
      </div>
    </div>

    <!-- WHAT -->
    <section id="what" class="v7-sect">
      <div class="v7-w">
        <div class="v7-what-intro v7-a" style="--d:0">
          <h2 class="v7-h2">Three things we do,<br />and nothing else.</h2>
        </div>

        <div class="v7-svc v7-a" style="--d:0">
          <div class="v7-svc-num">01</div>
          <div class="v7-svc-content">
            <h3 class="v7-svc-title">DevOps</h3>
            <p class="v7-svc-lead">Delivery platforms that let your team ship daily.</p>
            <p class="v7-svc-body">Infrastructure as code, GitOps pipelines, self-healing clusters. We build the system, wire the automation, and keep it running so you never think about infrastructure again.</p>
          </div>
        </div>

        <div class="v7-svc v7-a" style="--d:0">
          <div class="v7-svc-num">02</div>
          <div class="v7-svc-content">
            <h3 class="v7-svc-title">DevSecOps</h3>
            <p class="v7-svc-lead">Security that passes audits on the first review.</p>
            <p class="v7-svc-body">Supply chain integrity, runtime protection, continuous vulnerability management. Built into every pipeline and cluster from day one — not bolted on before audit week.</p>
          </div>
        </div>

        <div class="v7-svc v7-a" style="--d:0">
          <div class="v7-svc-num">03</div>
          <div class="v7-svc-content">
            <h3 class="v7-svc-title">AIOps</h3>
            <p class="v7-svc-lead">AI agents that do the work humans shouldn't.</p>
            <p class="v7-svc-body">Autonomous failure analysis, intelligent incident response, AI-driven security testing. Expert-level reports in minutes, fully auditable, production-proven.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- NUMBERS -->
    <section class="v7-numbers">
      <div class="v7-w v7-numbers-grid">
        <div class="v7-num v7-a" style="--d:0">
          <span class="v7-num-val">10+</span>
          <span class="v7-num-label">years in production</span>
        </div>
        <div class="v7-num v7-a" style="--d:1">
          <span class="v7-num-val">0</span>
          <span class="v7-num-label">junior engineers</span>
        </div>
        <div class="v7-num v7-a" style="--d:2">
          <span class="v7-num-val">Week 1</span>
          <span class="v7-num-label">first PR shipped</span>
        </div>
        <div class="v7-num v7-a" style="--d:3">
          <span class="v7-num-val">24/7</span>
          <span class="v7-num-label">we operate it too</span>
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="v7-sect">
      <div class="v7-w">
        <h2 class="v7-h2 v7-a" style="--d:0">Selected work</h2>

        <div class="v7-case v7-a" style="--d:0">
          <div class="v7-case-left">
            <span class="v7-case-ind">SaaS</span>
            <h3>Open-source CI overhaul</h3>
          </div>
          <div class="v7-case-right">
            <p>40% faster pipelines. 100% of images signed. Zero manual provisioning.</p>
          </div>
        </div>

        <div class="v7-case v7-a" style="--d:0">
          <div class="v7-case-left">
            <span class="v7-case-ind">Finance</span>
            <h3>European bank Azure migration</h3>
          </div>
          <div class="v7-case-right">
            <p>15 critical services. Zero downtime. PSD2 and GDPR compliant.</p>
          </div>
        </div>

        <div class="v7-case v7-a" style="--d:0">
          <div class="v7-case-left">
            <span class="v7-case-ind">Finance</span>
            <h3>U.S. bank core exchange pipeline</h3>
          </div>
          <div class="v7-case-right">
            <p>Zero audit findings. PCI DSS + FFIEC compliant. Minutes, not days.</p>
          </div>
        </div>

        <div class="v7-case v7-a" style="--d:0">
          <div class="v7-case-left">
            <span class="v7-case-ind">Telecom</span>
            <h3>Fiber network AI operations</h3>
          </div>
          <div class="v7-case-right">
            <p>95% faster incident reports. AI root cause analysis. ±15m fault precision.</p>
          </div>
        </div>

        <div class="v7-case-more v7-a" style="--d:0">
          <a href="/case-studies">Read full case studies →</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="v7-final">
      <div class="v7-w v7-a" style="--d:0">
        <h2 class="v7-final-h2">Let's talk about<br />your platform.</h2>
        <p class="v7-final-sub">Free architecture review. We assess your setup, find the gaps, show you production-grade.</p>
        <a href="/contact" class="v7-cta">Book architecture review →</a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="v7-footer">
      <div class="v7-w">
        <div class="v7-ft-grid">
          <div class="v7-ft-brand">
            <a href="/v7" class="v7-logo">catdev</a>
            <p>Senior DevOps & DevSecOps consulting.</p>
            <div class="v7-ft-addr">
              <strong>CATDEV LLC</strong>
              7901 4th St N STE 300<br />St. Petersburg, FL 33702
              <a href="mailto:info@catdev.io">info@catdev.io</a>
            </div>
          </div>
          <div class="v7-ft-cols">
            <div>
              <h4>Solutions</h4>
              <a href="/solutions/platform-engineering">Platform Engineering</a>
              <a href="/solutions/devsecops">DevSecOps</a>
              <a href="/solutions/cloud-migration">Cloud Migration</a>
              <a href="/solutions/ai-ops">AI Ops</a>
              <a href="/solutions/managed-ops">Managed Ops</a>
            </div>
            <div>
              <h4>Company</h4>
              <a href="/about">About</a>
              <a href="/approach">How We Work</a>
              <a href="/case-studies">Case Studies</a>
              <a href="/contact">Contact</a>
              <a href="/companies" class="v7-hl">Our Companies</a>
            </div>
            <div>
              <h4>Legal</h4>
              <a href="/privacy">Privacy</a>
              <a href="/imprint">Imprint</a>
            </div>
          </div>
        </div>
        <div class="v7-ft-bottom">
          <span>&copy; 2026 CATDEV LLC</span>
          <span>A <a href="/companies">catdev LLC</a> company</span>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('v7-nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));

      const burger = document.getElementById('v7-burger');
      const mob = document.getElementById('v7-mobile');
      let open = false;
      burger?.addEventListener('click', () => {
        open = !open;
        burger.classList.toggle('open', open);
        mob?.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
      mob?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        open = false; burger?.classList.remove('open'); mob?.classList.remove('open');
        document.body.style.overflow = '';
      }));

      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('vis'); obs.unobserve(e.target); }});
      }, { threshold: 0.06, rootMargin: '0px 0px -20px 0px' });
      document.querySelectorAll('.v7-a').forEach(el => obs.observe(el));

      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href'))?.scrollIntoView({ behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      .v7 {
        --bg: #050507;
        --fg: #f0f0f3;
        --fg2: #9898a4;
        --fg3: #4a4a56;
        --bdr: rgba(255,255,255,0.07);
        --ac: #2169B3;
        --ac2: #00D4FF;

        background: var(--bg);
        color: var(--fg);
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 400;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .v7-w { max-width: 980px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 2.5rem); }

      /* NAV */
      #v7-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 1rem 0; transition: all 0.3s; }
      #v7-nav.scrolled { background: rgba(5,5,7,0.9); backdrop-filter: blur(16px); border-bottom: 1px solid var(--bdr); }
      .v7-nav-row { display: flex; align-items: center; justify-content: space-between; }
      .v7-logo { font-size: 1.1rem; font-weight: 700; color: var(--fg); text-decoration: none; letter-spacing: -0.02em; }
      .v7-nav-links { display: flex; align-items: center; gap: 2.5rem; }
      .v7-nav-links a { font-size: 0.82rem; font-weight: 400; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v7-nav-links a:hover { color: var(--fg); }
      .v7-nav-accent { color: var(--ac2) !important; }

      #v7-burger { display: none; background: none; border: none; cursor: pointer; width: 24px; height: 16px; position: relative; }
      #v7-burger i { display: block; width: 100%; height: 1.5px; background: var(--fg); position: absolute; left: 0; transition: all 0.3s; }
      #v7-burger i:first-child { top: 2px; }
      #v7-burger i:last-child { bottom: 2px; }
      #v7-burger.open i:first-child { top: 50%; transform: translateY(-50%) rotate(45deg); }
      #v7-burger.open i:last-child { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

      .v7-mob { position: fixed; inset: 0; z-index: 40; background: rgba(5,5,7,0.98); display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
      .v7-mob.open { opacity: 1; pointer-events: auto; }
      .v7-mob a { font-size: 1.5rem; font-weight: 600; color: var(--fg); text-decoration: none; }

      @media (max-width: 768px) {
        .v7-nav-links { display: none; }
        #v7-burger { display: block; }
      }

      /* HERO */
      .v7-hero { min-height: 100vh; display: flex; align-items: center; padding: 7rem 0 5rem; }
      .v7-eyebrow { font-size: 0.75rem; font-weight: 500; color: var(--ac2); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 1.5rem; }
      .v7-display { font-size: clamp(2.8rem, 6vw, 4.8rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.04em; margin-bottom: 3rem; }
      .v7-display span { color: var(--ac2); }
      .v7-hero-row { display: flex; align-items: flex-end; justify-content: space-between; gap: 3rem; flex-wrap: wrap; padding-top: 2.5rem; border-top: 1px solid var(--bdr); }
      .v7-hero-sub { font-size: 1.05rem; color: var(--fg2); max-width: 380px; line-height: 1.7; }
      .v7-cta { display: inline-block; font-size: 0.82rem; font-weight: 600; color: var(--bg); background: var(--ac2); padding: 0.9rem 1.8rem; text-decoration: none; letter-spacing: -0.01em; transition: all 0.2s; white-space: nowrap; }
      .v7-cta:hover { background: var(--fg); transform: translateY(-1px); }

      /* STRIP */
      .v7-strip { padding: 2rem 0; border-top: 1px solid var(--bdr); border-bottom: 1px solid var(--bdr); }
      .v7-strip-inner { display: flex; align-items: center; justify-content: center; gap: 3.5rem; flex-wrap: wrap; }
      .v7-strip-inner img { height: 20px; width: auto; filter: grayscale(1) brightness(1) opacity(0.25); transition: opacity 0.3s; }
      .v7-strip-inner img:hover { filter: grayscale(1) brightness(1.3) opacity(0.5); }
      .v7-inv { filter: brightness(0) invert(1) opacity(0.25) !important; }
      .v7-inv:hover { filter: brightness(0) invert(1) opacity(0.5) !important; }

      /* SECTIONS */
      .v7-sect { padding: 6rem 0; }
      .v7-h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 3.5rem; }

      /* SERVICES */
      .v7-what-intro { margin-bottom: 4rem; }
      .v7-svc { display: grid; grid-template-columns: 80px 1fr; gap: 2rem; padding: 2.5rem 0; border-top: 1px solid var(--bdr); }
      .v7-svc:last-of-type { border-bottom: 1px solid var(--bdr); }
      .v7-svc-num { font-size: 0.7rem; font-weight: 500; color: var(--fg3); padding-top: 0.2rem; }
      .v7-svc-title { font-size: 1.4rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
      .v7-svc-lead { font-size: 1rem; color: var(--ac2); margin-bottom: 0.5rem; font-weight: 500; }
      .v7-svc-body { font-size: 0.92rem; color: var(--fg2); line-height: 1.75; max-width: 580px; }

      /* NUMBERS */
      .v7-numbers { padding: 4rem 0; background: var(--ac); background: linear-gradient(135deg, var(--ac) 0%, #1a4f8a 100%); }
      .v7-numbers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
      .v7-num { text-align: center; }
      .v7-num-val { display: block; font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 800; letter-spacing: -0.03em; color: #fff; }
      .v7-num-label { display: block; font-size: 0.75rem; color: rgba(255,255,255,0.6); margin-top: 0.3rem; }

      /* CASES */
      .v7-case { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; padding: 2rem 0; border-top: 1px solid var(--bdr); align-items: center; }
      .v7-case:last-of-type { border-bottom: 1px solid var(--bdr); }
      .v7-case-ind { font-size: 0.65rem; font-weight: 500; color: var(--ac2); text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 0.3rem; }
      .v7-case-left h3 { font-size: 1.1rem; font-weight: 600; letter-spacing: -0.01em; }
      .v7-case-right p { font-size: 0.9rem; color: var(--fg2); line-height: 1.7; }
      .v7-case-more { margin-top: 2rem; }
      .v7-case-more a { font-size: 0.82rem; font-weight: 500; color: var(--fg3); text-decoration: none; transition: color 0.2s; }
      .v7-case-more a:hover { color: var(--fg); }

      /* CTA */
      .v7-final { padding: 7rem 0; border-top: 1px solid var(--bdr); }
      .v7-final-h2 { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 1rem; }
      .v7-final-sub { font-size: 1rem; color: var(--fg2); max-width: 440px; margin-bottom: 2rem; line-height: 1.7; }

      /* FOOTER */
      .v7-footer { border-top: 1px solid var(--bdr); padding: 3rem 0 1.5rem; }
      .v7-ft-grid { display: grid; grid-template-columns: 1fr 2fr; gap: 4rem; }
      .v7-ft-brand p { font-size: 0.78rem; color: var(--fg3); margin-top: 0.5rem; }
      .v7-ft-addr { font-size: 0.7rem; color: var(--fg3); line-height: 1.8; margin-top: 1.2rem; }
      .v7-ft-addr strong { color: var(--fg); font-weight: 600; display: block; }
      .v7-ft-addr a { color: var(--ac2); text-decoration: none; display: block; margin-top: 0.3rem; }
      .v7-ft-cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
      .v7-ft-cols h4 { font-size: 0.65rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--fg); margin-bottom: 0.8rem; }
      .v7-ft-cols a { display: block; font-size: 0.78rem; color: var(--fg3); text-decoration: none; padding: 0.2rem 0; transition: color 0.2s; }
      .v7-ft-cols a:hover { color: var(--fg); }
      .v7-hl { color: var(--ac2) !important; }
      .v7-ft-bottom { display: flex; justify-content: space-between; margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--bdr); font-size: 0.63rem; color: var(--fg3); }
      .v7-ft-bottom a { color: var(--fg2); text-decoration: none; }

      /* ANIM */
      .v7-a { opacity: 0; transform: translateY(20px); transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); transition-delay: calc(var(--d, 0) * 0.1s); }
      .v7-a.vis { opacity: 1; transform: translateY(0); }

      /* RESPONSIVE */
      @media (max-width: 768px) {
        .v7-hero-row { flex-direction: column; align-items: flex-start; }
        .v7-svc { grid-template-columns: 1fr; gap: 0.5rem; }
        .v7-svc-num { display: none; }
        .v7-numbers-grid { grid-template-columns: 1fr 1fr; }
        .v7-case { grid-template-columns: 1fr; gap: 0.5rem; }
        .v7-ft-grid { grid-template-columns: 1fr; }
        .v7-ft-cols { grid-template-columns: 1fr 1fr; }
        .v7-ft-bottom { flex-direction: column; gap: 0.3rem; }
      }
    </style>

  </body>
</html>
