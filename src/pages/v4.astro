---
import '../styles/global.css';
import { caseStudies } from '../data/caseStudies';

const GA_ID = 'G-4TDGDGK41V';
const featured = caseStudies.filter(cs => cs.featured).slice(0, 3);

const capabilities = [
  { label: 'DevOps', desc: 'Terraform, Kubernetes, CI/CD, GitOps. Infrastructure as code, deployed and reconciled automatically.' },
  { label: 'DevSecOps', desc: 'Supply chain hardening, image signing, SBOM, vulnerability management. Compliance baked in from day one.' },
  { label: 'GitOps', desc: 'Declarative everything. ArgoCD, Flux, drift detection. Git is your control plane.' },
  { label: 'AIOps', desc: 'AI agents for failure analysis, intelligent alerting, autonomous ops. Expert reports in minutes.' },
];

const values = [
  { title: 'Senior engineers only', body: 'Every person on your project has 10+ years in production. No juniors, no subcontracting.' },
  { title: 'We operate what we build', body: 'Not advisory-only. We deploy, monitor, patch, and do incident response. Real skin in the game.' },
  { title: 'Ship from week one', body: 'No discovery sprints, no slide decks. We embed with your team and start delivering immediately.' },
  { title: 'Compliance-native', body: 'SOC2, ISO 27001, PCI DSS, HIPAA. We\'ve built and passed these audits for banks and fintechs.' },
];

const navItems = [
  { label: 'Capabilities', href: '#capabilities' },
  { label: 'Work', href: '#work' },
  { label: 'About', href: '#about' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, GitOps, and AIOps engineers who build and operate cloud-native platforms." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:description" content="Senior engineers who build and operate cloud-native platforms." />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="v4-body">

    <!-- NAV -->
    <header id="v4-nav" class="fixed top-0 left-0 right-0 z-50 v4-nav-transition">
      <div class="v4-nav-bg"></div>
      <div class="v4-container relative flex items-center justify-between h-16">
        <a href="/v4" class="v4-logo">cat<span>dev</span></a>
        <nav class="hidden md:flex items-center gap-8">
          {navItems.map(item => (
            <a href={item.href} class="v4-nav-link">{item.label}</a>
          ))}
        </nav>
        <a href="/contact" class="v4-cta-sm">Get in touch</a>
        <button id="v4-menu-btn" class="md:hidden text-white" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" /></svg>
        </button>
      </div>
    </header>

    <!-- Mobile menu -->
    <div id="v4-mobile-menu" class="fixed inset-0 z-40 bg-[#0a0a0a]/98 backdrop-blur-xl flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">
      {navItems.map(item => (
        <a href={item.href} class="v4-mobile-link">{item.label}</a>
      ))}
      <a href="/contact" class="v4-cta-sm mt-4">Get in touch</a>
    </div>

    <!-- HERO -->
    <section class="v4-hero">
      <div class="v4-container v4-hero-inner">
        <p class="v4-mono v4-accent v4-fade" style="animation-delay: 0.2s">catdev consulting</p>
        <h1 class="v4-hero-h1 v4-fade" style="animation-delay: 0.4s">
          We build platforms<br />that let you <em>ship.</em>
        </h1>
        <p class="v4-hero-sub v4-fade" style="animation-delay: 0.6s">
          Senior DevOps and DevSecOps engineers. Kubernetes, Terraform, GitOps, supply chain security.
          We embed with your team, deliver from week one, and stay through production.
        </p>
        <div class="v4-hero-actions v4-fade" style="animation-delay: 0.8s">
          <a href="/contact" class="v4-btn-primary">Book architecture review <span>→</span></a>
          <a href="#capabilities" class="v4-btn-ghost">What we do</a>
        </div>
        <div class="v4-hero-clients v4-fade" style="animation-delay: 1s">
          <p class="v4-mono v4-muted">Trusted by</p>
          <div class="v4-client-logos">
            <img src="/logos/callflows_brand_no_claim.webp" alt="Callflows" />
            <img src="/logos/Logo-Color.svg" alt="Growthtastic" />
            <img src="/logos/techgardens.png" alt="techgardens" class="v4-logo-invert" />
            <img src="/logos/theiafiber.png" alt="theiafiber" class="v4-logo-invert" />
          </div>
        </div>
      </div>
    </section>

    <!-- CAPABILITIES -->
    <section id="capabilities" class="v4-section v4-border-t">
      <div class="v4-container">
        <div class="v4-section-header reveal">
          <p class="v4-mono v4-accent">01 — Capabilities</p>
          <h2 class="v4-section-h2">Four disciplines.<br />One team.</h2>
        </div>
        <div class="v4-cap-grid">
          {capabilities.map((cap, i) => (
            <div class="v4-cap-item reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="v4-cap-label">{cap.label}</div>
              <p class="v4-cap-desc">{cap.desc}</p>
            </div>
          ))}
        </div>
        <div class="v4-tech-ribbon reveal">
          {['Kubernetes', 'Terraform', 'ArgoCD', 'Sigstore', 'Prometheus', 'Falco', 'Vault', 'GitHub Actions', 'Flux', 'Trivy'].map(t => (
            <span class="v4-tech-tag">{t}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="v4-section v4-section-alt v4-border-t">
      <div class="v4-container">
        <div class="v4-section-header reveal">
          <p class="v4-mono v4-accent">02 — Selected Work</p>
          <h2 class="v4-section-h2">From startups to banks.</h2>
        </div>
        <div class="v4-work-grid">
          {featured.map((study, i) => (
            <a href={`/case-studies/${study.slug}`} class="v4-work-card reveal" style={`transition-delay: ${i * 80}ms`}>
              <div class="v4-work-meta">
                <span class="v4-mono v4-accent">{study.industry}</span>
                <span class="v4-mono v4-muted">{study.clientType}</span>
              </div>
              <h3 class="v4-work-title">{study.title}</h3>
              <p class="v4-work-desc">{study.problem}</p>
              <ul class="v4-work-outcomes">
                {study.outcome.slice(0, 2).map(r => (
                  <li>✓ {r}</li>
                ))}
              </ul>
              <div class="v4-work-tech">
                {study.technologies.slice(0, 4).map(t => (
                  <span>{t}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
        <div class="v4-work-more reveal">
          <a href="/case-studies" class="v4-btn-ghost">All case studies →</a>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="v4-section v4-border-t">
      <div class="v4-container">
        <div class="v4-about-layout reveal">
          <div class="v4-about-left">
            <p class="v4-mono v4-accent">03 — Why Us</p>
            <h2 class="v4-section-h2">Engineers,<br />not consultants.</h2>
            <p class="v4-about-body">
              We've been the ones responding to 3 AM pages, migrating banking platforms with zero downtime,
              and hardening supply chains for projects processing millions of builds. That experience shapes
              every platform we build.
            </p>
          </div>
          <div class="v4-about-right">
            {values.map((v, i) => (
              <div class="v4-value-item reveal" style={`transition-delay: ${i * 60}ms`}>
                <h3 class="v4-value-title">{v.title}</h3>
                <p class="v4-value-body">{v.body}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ENGAGE -->
    <section class="v4-section v4-section-alt v4-border-t">
      <div class="v4-container">
        <div class="v4-section-header reveal">
          <p class="v4-mono v4-accent">04 — Engagement</p>
          <h2 class="v4-section-h2">Three ways to work together.</h2>
        </div>
        <div class="v4-engage-grid">
          <div class="v4-engage-card reveal">
            <p class="v4-mono v4-accent">Platform Build</p>
            <p class="v4-mono v4-muted">Fixed scope · 6–12 weeks</p>
            <p class="v4-engage-desc">Complete delivery platform from infrastructure to CI/CD to observability. Delivered as code with runbooks.</p>
          </div>
          <div class="v4-engage-card reveal" style="transition-delay: 80ms">
            <p class="v4-mono v4-accent">Managed Ops</p>
            <p class="v4-mono v4-muted">Monthly retainer</p>
            <p class="v4-engage-desc">We run your platform. Monitoring, patching, incident response, vulnerability management, compliance.</p>
          </div>
          <div class="v4-engage-card reveal" style="transition-delay: 160ms">
            <p class="v4-mono v4-accent">Security Hardening</p>
            <p class="v4-mono v4-muted">Assessment · 3–6 weeks</p>
            <p class="v4-engage-desc">SBOM integration, image signing, runtime policies, compliance documentation. Audit-ready fast.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="v4-cta v4-border-t">
      <div class="v4-container v4-cta-inner reveal">
        <h2 class="v4-cta-h2">Ready to stop<br />fighting infrastructure?</h2>
        <p class="v4-cta-sub">Book a free architecture review. We'll assess your setup, find the gaps, and show you what production-grade looks like.</p>
        <a href="/contact" class="v4-btn-primary">Book architecture review <span>→</span></a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="v4-footer v4-border-t">
      <div class="v4-container">
        <div class="v4-footer-grid">
          <div class="v4-footer-brand">
            <a href="/v4" class="v4-logo v4-logo-footer">cat<span>dev</span></a>
            <p class="v4-footer-desc">Senior DevOps and DevSecOps engineers. Cloud-native platforms built, operated, and hardened.</p>
            <div class="v4-footer-address">
              <p><strong>CATDEV LLC</strong></p>
              <p>7901 4th St N STE 300</p>
              <p>St. Petersburg, FL 33702</p>
              <a href="mailto:info@catdev.io">info@catdev.io</a>
            </div>
          </div>
          <div class="v4-footer-links">
            <div>
              <p class="v4-footer-heading">Solutions</p>
              <a href="/solutions/platform-engineering">Platform Engineering</a>
              <a href="/solutions/devsecops">DevSecOps</a>
              <a href="/solutions/cloud-migration">Cloud Migration</a>
              <a href="/solutions/ai-ops">AI Ops</a>
              <a href="/solutions/managed-ops">Managed Ops</a>
            </div>
            <div>
              <p class="v4-footer-heading">Company</p>
              <a href="/about">About</a>
              <a href="/approach">How We Work</a>
              <a href="/case-studies">Case Studies</a>
              <a href="/contact">Contact</a>
              <a href="/companies" class="v4-accent">Our Companies</a>
            </div>
            <div>
              <p class="v4-footer-heading">Legal</p>
              <a href="/privacy">Privacy Policy</a>
              <a href="/imprint">Imprint</a>
            </div>
          </div>
        </div>
        <div class="v4-footer-bottom">
          <p>&copy; 2026 CATDEV LLC</p>
          <p>A <a href="/companies">catdev LLC</a> company</p>
        </div>
      </div>
    </footer>

    <!-- SCRIPTS -->
    <script>
      // Nav scroll
      const nav = document.getElementById('v4-nav');
      window.addEventListener('scroll', () => nav?.classList.toggle('v4-nav-scrolled', window.scrollY > 50));

      // Mobile menu
      const menuBtn = document.getElementById('v4-menu-btn');
      const mobileMenu = document.getElementById('v4-mobile-menu');
      let menuOpen = false;
      menuBtn?.addEventListener('click', () => {
        menuOpen = !menuOpen;
        mobileMenu?.classList.toggle('opacity-0', !menuOpen);
        mobileMenu?.classList.toggle('pointer-events-none', !menuOpen);
        document.body.style.overflow = menuOpen ? 'hidden' : '';
      });
      mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
        menuOpen = false;
        mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
        document.body.style.overflow = '';
      }));

      // Reveal
      const observer = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('active'); observer.unobserve(e.target); }});
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', function(e) {
          e.preventDefault();
          document.querySelector(this.getAttribute('href'))?.scrollIntoView({ behavior: 'smooth' });
        });
      });
    </script>

    <style is:global>
      /* ═══════ V4 Design System ═══════ */
      .v4-body {
        background: #0a0a0a;
        color: #e8e4dd;
        font-family: 'DM Sans', -apple-system, sans-serif;
        font-weight: 300;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .v4-body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
      }

      .v4-container { max-width: 1100px; margin: 0 auto; padding: 0 clamp(1.5rem, 5vw, 3rem); }

      /* ── Type ── */
      .v4-mono { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; }
      .v4-accent { color: #00D4FF; }
      .v4-muted { color: #666; }

      /* ── Nav ── */
      .v4-nav-bg { position: absolute; inset: 0; background: rgba(10,10,10,0.9); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.04); opacity: 0; transition: opacity 0.3s; }
      .v4-nav-scrolled .v4-nav-bg { opacity: 1; }
      .v4-nav-transition { transition: all 0.3s; }
      .v4-nav-link { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: #666; text-decoration: none; transition: color 0.3s; }
      .v4-nav-link:hover { color: #e8e4dd; }
      .v4-logo { font-family: 'DM Mono', monospace; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.15em; text-transform: lowercase; color: #e8e4dd; text-decoration: none; }
      .v4-logo span { color: #00D4FF; }
      .v4-cta-sm { font-family: 'DM Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: #00D4FF; border: 1px solid rgba(0,212,255,0.3); padding: 0.5rem 1.2rem; text-decoration: none; transition: all 0.3s; }
      .v4-cta-sm:hover { background: #00D4FF; color: #0a0a0a; }
      .v4-mobile-link { font-family: 'Instrument Serif', serif; font-size: 2rem; color: #e8e4dd; text-decoration: none; }

      /* ── Hero ── */
      .v4-hero { min-height: 100vh; display: flex; align-items: center; position: relative; padding-top: 5rem; }
      .v4-hero::before { content: ''; position: absolute; top: 0; right: -20%; width: 50%; height: 50%; background: radial-gradient(ellipse, rgba(0,212,255,0.04) 0%, transparent 70%); pointer-events: none; }
      .v4-hero-inner { max-width: 720px; }
      .v4-hero-h1 { font-family: 'Instrument Serif', serif; font-weight: 400; font-size: clamp(2.8rem, 6.5vw, 5rem); line-height: 1.08; letter-spacing: -0.02em; margin: 1.5rem 0; }
      .v4-hero-h1 em { font-style: italic; color: #00D4FF; }
      .v4-hero-sub { font-size: 1.1rem; color: #999; max-width: 520px; line-height: 1.8; margin-bottom: 2.5rem; }
      .v4-hero-actions { display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; margin-bottom: 5rem; }
      .v4-hero-clients { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 2.5rem; }
      .v4-client-logos { display: flex; align-items: center; gap: 2.5rem; margin-top: 1rem; flex-wrap: wrap; }
      .v4-client-logos img { height: 28px; width: auto; filter: grayscale(1) brightness(1.2) opacity(0.5); transition: opacity 0.3s; }
      .v4-client-logos img:hover { filter: grayscale(1) brightness(1.4) opacity(0.8); }
      .v4-logo-invert { filter: brightness(0) invert(1) opacity(0.5) !important; }
      .v4-logo-invert:hover { filter: brightness(0) invert(1) opacity(0.8) !important; }

      /* ── Buttons ── */
      .v4-btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; background: #00D4FF; color: #0a0a0a; padding: 0.9rem 1.8rem; text-decoration: none; transition: all 0.3s; font-weight: 500; }
      .v4-btn-primary:hover { background: #e8e4dd; transform: translateY(-1px); }
      .v4-btn-ghost { font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: #999; text-decoration: none; transition: color 0.3s; }
      .v4-btn-ghost:hover { color: #e8e4dd; }

      /* ── Sections ── */
      .v4-section { padding: 7rem 0; }
      .v4-section-alt { background: #0f0f0f; }
      .v4-border-t { border-top: 1px solid rgba(255,255,255,0.06); }
      .v4-section-header { margin-bottom: 4rem; }
      .v4-section-h2 { font-family: 'Instrument Serif', serif; font-weight: 400; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; margin-top: 1rem; }

      /* ── Capabilities ── */
      .v4-cap-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border: 1px solid rgba(255,255,255,0.06); }
      .v4-cap-item { padding: 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); border-right: 1px solid rgba(255,255,255,0.06); transition: background 0.3s; }
      .v4-cap-item:hover { background: rgba(255,255,255,0.02); }
      .v4-cap-item:nth-child(2n) { border-right: none; }
      .v4-cap-item:nth-child(n+3) { border-bottom: none; }
      .v4-cap-label { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: #00D4FF; margin-bottom: 0.8rem; }
      .v4-cap-desc { font-size: 0.95rem; color: #999; line-height: 1.7; }
      .v4-tech-ribbon { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 3rem; }
      .v4-tech-tag { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; color: #666; padding: 0.4rem 0.8rem; border: 1px solid rgba(255,255,255,0.06); }

      /* ── Work ── */
      .v4-work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .v4-work-card { display: block; padding: 2.5rem; border: 1px solid rgba(255,255,255,0.06); text-decoration: none; color: inherit; transition: all 0.3s; }
      .v4-work-card:hover { border-color: rgba(0,212,255,0.2); transform: translateY(-2px); }
      .v4-work-meta { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 1.2rem; }
      .v4-work-title { font-family: 'Instrument Serif', serif; font-size: 1.3rem; font-weight: 400; line-height: 1.3; margin-bottom: 0.8rem; color: #e8e4dd; }
      .v4-work-desc { font-size: 0.85rem; color: #777; line-height: 1.7; margin-bottom: 1.2rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
      .v4-work-outcomes { list-style: none; margin-bottom: 1.5rem; }
      .v4-work-outcomes li { font-size: 0.8rem; color: #ccc; padding: 0.2rem 0; }
      .v4-work-tech { display: flex; flex-wrap: wrap; gap: 0.4rem; }
      .v4-work-tech span { font-family: 'DM Mono', monospace; font-size: 0.55rem; letter-spacing: 0.08em; text-transform: uppercase; color: #555; padding: 0.3rem 0.6rem; border: 1px solid rgba(255,255,255,0.05); }
      .v4-work-more { margin-top: 3rem; }

      /* ── About ── */
      .v4-about-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
      .v4-about-body { font-size: 1.05rem; color: #999; line-height: 1.8; margin-top: 1.5rem; }
      .v4-about-right { display: flex; flex-direction: column; gap: 0; }
      .v4-value-item { padding: 1.8rem 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
      .v4-value-item:last-child { border-bottom: none; }
      .v4-value-title { font-family: 'DM Mono', monospace; font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: #e8e4dd; margin-bottom: 0.4rem; }
      .v4-value-body { font-size: 0.9rem; color: #777; line-height: 1.7; }

      /* ── Engage ── */
      .v4-engage-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
      .v4-engage-card { padding: 2.5rem; border: 1px solid rgba(255,255,255,0.06); }
      .v4-engage-desc { font-size: 0.9rem; color: #777; line-height: 1.7; margin-top: 1rem; }

      /* ── CTA ── */
      .v4-cta { padding: 8rem 0; }
      .v4-cta-inner { max-width: 600px; }
      .v4-cta-h2 { font-family: 'Instrument Serif', serif; font-weight: 400; font-size: clamp(2rem, 4vw, 3rem); line-height: 1.15; margin-bottom: 1.5rem; }
