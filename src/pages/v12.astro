---
import '../styles/global.css';
const GA_ID = 'G-4TDGDGK41V';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="catdev consulting — senior DevOps, DevSecOps, and AIOps engineers." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content="catdev consulting" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    <title>catdev consulting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
    <script define:vars={{ GA_ID }}>window.GA_ID = GA_ID;</script>
  </head>

  <body class="p-body">

    <!-- NAV — minimal floating top-left / top-right -->
    <nav class="p-nav">
      <a href="/v12" class="p-nav-logo">catdev <em>consulting</em></a>
      <a href="#contact" class="p-nav-contact">Get in touch</a>
    </nav>

    <!-- SECTION 1: HERO — full viewport, centered poem-like headline -->
    <section class="p-snap p-hero">
      <div class="p-hero-inner">
        <p class="p-hero-above">DevOps · DevSecOps · AIOps</p>
        <h1 class="p-hero-h">
          The best infrastructure<br/>
          is the one your team<br/>
          <em>forgets is there.</em>
        </h1>
        <p class="p-hero-below">Senior engineers who embed, build, and leave you independent.</p>
      </div>
      <div class="p-scroll-hint">
        <span>Scroll</span>
        <svg width="16" height="24" viewBox="0 0 16 24" fill="none"><path d="M8 4v16m0 0l-5-5m5 5l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </section>

    <!-- SECTION 2: BELIEF — split screen, left text right empty/accent -->
    <section class="p-snap p-belief">
      <div class="p-split">
        <div class="p-split-left">
          <span class="p-eyebrow">What we believe</span>
          <h2 class="p-split-h">Platforms should<br/>accelerate teams,<br/>not require them.</h2>
          <p class="p-split-p">Most infrastructure work creates dependency. Ours eliminates it. We build systems your team fully owns — then we leave.</p>
        </div>
        <div class="p-split-right p-split-accent">
          <div class="p-accent-block">
            <span class="p-accent-num">0</span>
            <span class="p-accent-label">vendor lock-in.<br/>ever.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION 3: DISCIPLINES — stacked horizontal bands -->
    <section class="p-snap p-disc-section">
      <div class="p-disc-wrap">
        <div class="p-disc" data-n="01">
          <div class="p-disc-left">
            <span class="p-disc-num">01</span>
            <h3 class="p-disc-name">DevOps</h3>
          </div>
          <p class="p-disc-desc">CI/CD pipelines, Kubernetes, Terraform, observability. We design the deployment systems your team ships with every day.</p>
        </div>
        <div class="p-disc" data-n="02">
          <div class="p-disc-left">
            <span class="p-disc-num">02</span>
            <h3 class="p-disc-name">DevSecOps</h3>
          </div>
          <p class="p-disc-desc">Security shifted left. Supply chain hardening, automated scanning, compliance frameworks — without slowing anyone down.</p>
        </div>
        <div class="p-disc" data-n="03">
          <div class="p-disc-left">
            <span class="p-disc-num">03</span>
            <h3 class="p-disc-name">AIOps</h3>
          </div>
          <p class="p-disc-desc">ML-driven incident response, predictive scaling, intelligent alerting, and LLM agents deployed into your infrastructure.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 4: HOW — narrative flow, no grid -->
    <section class="p-snap p-how">
      <div class="p-how-inner">
        <span class="p-eyebrow">How it works</span>
        <div class="p-how-narrative">
          <p><strong>First,</strong> we audit your infrastructure, pipelines, and security posture — documenting bottlenecks, risks, and quick wins.</p>
          <p><strong>Then,</strong> we design the target architecture with your team. Milestones, ownership, and success metrics — agreed before any code.</p>
          <p><strong>Next,</strong> our engineers join your squad. Standups, Slack, on-call. We ship iteratively and transfer knowledge continuously.</p>
          <p><strong>Finally,</strong> we harden everything — runbooks, chaos tests, alerting — until your team owns it completely. Then we step away.</p>
        </div>
      </div>
    </section>

    <!-- SECTION 5: RESULTS — large numbers, dark background -->
    <section class="p-snap p-results">
      <div class="p-results-inner">
        <div class="p-result-row">
          <span class="p-result-big">40%</span>
          <span class="p-result-text">faster deployments<br/>across engagements</span>
        </div>
        <div class="p-result-row">
          <span class="p-result-big">0</span>
          <span class="p-result-text">security incidents<br/>post-engagement</span>
        </div>
        <div class="p-result-row">
          <span class="p-result-big">95%</span>
          <span class="p-result-text">pipeline uptime<br/>sustained after handoff</span>
        </div>
      </div>
    </section>

    <!-- SECTION 6: CTA -->
    <section class="p-snap p-contact" id="contact">
      <div class="p-contact-inner">
        <h2 class="p-contact-h">
          Tell us what's<br/>slowing you down<em>.</em>
        </h2>
        <p class="p-contact-sub">We'll scope an engagement in 48 hours.</p>
        <a href="mailto:hello@catdev.io" class="p-contact-btn">hello@catdev.io</a>
        <div class="p-contact-footer">
          <span>© 2026 catdev LLC</span>
          <a href="/companies">Our Companies</a>
          <a href="https://github.com/catdev-llc" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </section>

    <style>
      /* ===== BASE ===== */
      .p-body {
        margin: 0;
        padding: 0;
        background: #f5f0eb;
        color: #1e1b4b;
        font-family: 'Manrope', sans-serif;
        font-size: 17px;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      .p-body * { box-sizing: border-box; }

      /* ===== SCROLL SNAP ===== */
      @media (min-height: 600px) and (min-width: 768px) {
        .p-body {
          scroll-snap-type: y mandatory;
          overflow-y: scroll;
          height: 100vh;
        }
        .p-snap {
          scroll-snap-align: start;
        }
      }

      .p-snap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }

      /* ===== NAV ===== */
      .p-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 40px;
        pointer-events: none;
      }

      .p-nav > * { pointer-events: auto; }

      .p-nav-logo {
        font-family: 'Manrope', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: #1e1b4b;
        text-decoration: none;
        letter-spacing: -0.01em;
      }

      .p-nav-logo em {
        font-family: 'Playfair Display', serif;
        font-weight: 400;
        font-style: italic;
        color: #6d5a8a;
      }

      .p-nav-contact {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #1e1b4b;
        text-decoration: none;
        border-bottom: 1.5px solid #e07a5f;
        padding-bottom: 2px;
        transition: color 0.2s;
      }

      .p-nav-contact:hover { color: #e07a5f; }

      /* ===== HERO ===== */
      .p-hero {
        flex-direction: column;
        text-align: center;
        padding: 0 40px;
      }

      .p-hero-inner {
        max-width: 800px;
      }

      .p-hero-above {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #e07a5f;
        margin: 0 0 40px;
      }

      .p-hero-h {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.4rem, 5.5vw, 4.2rem);
        font-weight: 400;
        line-height: 1.2;
        margin: 0 0 40px;
        color: #1e1b4b;
      }

      .p-hero-h em {
        font-style: italic;
        color: #e07a5f;
      }

      .p-hero-below {
        font-size: 1rem;
        color: #7c7a91;
        margin: 0;
      }

      .p-scroll-hint {
        position: absolute;
        bottom: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        color: #b0aec0;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        animation: p-bob 2s ease-in-out infinite;
      }

      @keyframes p-bob {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(8px); }
      }

      /* ===== BELIEF (SPLIT) ===== */
      .p-belief { padding: 0; }

      .p-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        width: 100%;
        min-height: 100vh;
      }

      .p-split-left {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 80px 72px;
      }

      .p-eyebrow {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: #e07a5f;
        margin-bottom: 32px;
        display: block;
      }

      .p-split-h {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        font-weight: 400;
        line-height: 1.25;
        margin: 0 0 24px;
        color: #1e1b4b;
      }

      .p-split-p {
        font-size: 1rem;
        color: #7c7a91;
        margin: 0;
        max-width: 420px;
        line-height: 1.75;
      }

      .p-split-right {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .p-split-accent {
        background: #1e1b4b;
      }

      .p-accent-block {
        text-align: center;
      }

      .p-accent-num {
        font-family: 'Playfair Display', serif;
        font-size: 10rem;
        font-weight: 700;
        line-height: 1;
        color: #e07a5f;
        display: block;
      }

      .p-accent-label {
        font-size: 0.85rem;
        color: #b0aec0;
        display: block;
        margin-top: 16px;
        line-height: 1.5;
      }

      /* ===== DISCIPLINES ===== */
      .p-disc-section {
        padding: 0 40px;
      }

      .p-disc-wrap {
        width: 100%;
        max-width: 960px;
      }

      .p-disc {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 40px;
        padding: 48px 0;
        border-bottom: 1px solid rgba(30,27,75,0.12);
        align-items: baseline;
        transition: padding-left 0.4s ease;
      }

      .p-disc:first-child {
        border-top: 1px solid rgba(30,27,75,0.12);
      }

      .p-disc:hover {
        padding-left: 16px;
      }

      .p-disc-left {
        display: flex;
        align-items: baseline;
        gap: 20px;
      }

      .p-disc-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: #e07a5f;
      }

      .p-disc-name {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 400;
        margin: 0;
        color: #1e1b4b;
      }

      .p-disc-desc {
        font-size: 0.95rem;
        color: #7c7a91;
        margin: 0;
        line-height: 1.75;
      }

      /* ===== HOW ===== */
      .p-how {
        padding: 0 40px;
        background: #eae5df;
      }

      .p-how-inner {
        max-width: 620px;
      }

      .p-how-narrative p {
        font-size: 1.15rem;
        line-height: 1.85;
        color: #4a4762;
        margin: 0 0 32px;
      }

      .p-how-narrative p:last-child { margin-bottom: 0; }

      .p-how-narrative strong {
        font-family: 'Playfair Display', serif;
        font-weight: 400;
        font-style: italic;
        color: #e07a5f;
        font-size: 1.2rem;
      }

      /* ===== RESULTS ===== */
      .p-results {
        background: #1e1b4b;
        padding: 0 40px;
      }

      .p-results-inner {
        width: 100%;
        max-width: 900px;
      }

      .p-result-row {
        display: flex;
        align-items: baseline;
        gap: 48px;
        padding: 48px 0;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }

      .p-result-row:first-child {
        border-top: 1px solid rgba(255,255,255,0.08);
      }

      .p-result-big {
        font-family: 'Playfair Display', serif;
        font-size: clamp(4rem, 8vw, 7rem);
        font-weight: 700;
        color: #e07a5f;
        line-height: 1;
        min-width: 260px;
      }

      .p-result-text {
        font-size: 0.95rem;
        color: #b0aec0;
        line-height: 1.6;
      }

      /* ===== CONTACT ===== */
      .p-contact {
        flex-direction: column;
        padding: 0 40px;
      }

      .p-contact-inner {
        text-align: center;
        max-width: 600px;
      }

      .p-contact-h {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 4.5vw, 3.2rem);
        font-weight: 400;
        line-height: 1.2;
        margin: 0 0 16px;
        color: #1e1b4b;
      }

      .p-contact-h em {
        font-style: normal;
        color: #e07a5f;
      }

      .p-contact-sub {
        font-size: 1rem;
        color: #7c7a91;
        margin: 0 0 48px;
      }

      .p-contact-btn {
        display: inline-block;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.9rem;
        color: #1e1b4b;
        text-decoration: none;
        border: 1.5px solid #1e1b4b;
        padding: 16px 48px;
        border-radius: 40px;
        transition: all 0.3s ease;
      }

      .p-contact-btn:hover {
        background: #e07a5f;
        border-color: #e07a5f;
        color: #fff;
      }

      .p-contact-footer {
        margin-top: 80px;
        display: flex;
        gap: 32px;
        justify-content: center;
        font-size: 0.75rem;
        color: #b0aec0;
      }

      .p-contact-footer a {
        color: #b0aec0;
        text-decoration: none;
        transition: color 0.2s;
      }

      .p-contact-footer a:hover { color: #1e1b4b; }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 900px) {
        .p-split {
          grid-template-columns: 1fr;
        }

        .p-split-left {
          padding: 80px 40px 40px;
        }

        .p-split-right.p-split-accent {
          min-height: 50vh;
        }

        .p-disc {
          grid-template-columns: 1fr;
          gap: 12px;
        }

        .p-result-row {
          flex-direction: column;
          gap: 8px;
        }

        .p-result-big { min-width: auto; }

        .p-nav { padding: 20px 24px; }
      }

      @media (max-width: 600px) {
        .p-hero-h { font-size: 2rem; }

        .p-accent-num { font-size: 6rem; }

        .p-split-left { padding: 60px 24px 40px; }

        .p-disc-section,
        .p-how,
        .p-results,
        .p-contact { padding: 0 24px; }

        .p-scroll-hint { display: none; }
      }
    </style>

    <script>
      // Smooth scroll
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const target = document.querySelector(a.getAttribute('href'));
          if (target) target.scrollIntoView({ behavior: 'smooth' });
        });
      });

      // GA
      if (window.GA_ID) {
        const s = document.createElement('script');
        s.src = `https://www.googletagmanager.com/gtag/js?id=${window.GA_ID}`;
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', window.GA_ID);
      }
    </script>

  </body>
</html>
