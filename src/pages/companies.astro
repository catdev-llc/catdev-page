---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/shared/Breadcrumbs.astro';
import CTASection from '../components/shared/CTASection.astro';

const companies = [
  {
    name: 'catdev consulting',
    domain: 'catdev.io',
    href: '/',
    description: 'Senior-only DevOps, DevSecOps, and platform engineering. We build, secure, and operate cloud-native delivery platforms for SaaS teams, banks, and enterprises.',
    focus: ['DevOps & GitOps', 'DevSecOps & Supply Chain Security', 'Platform Engineering', 'AI Ops & Intelligent Automation', 'Managed Operations', 'Offensive Security'],
    color: 'cyan',
    gradient: 'from-cyan to-electric',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0h.375a2.625 2.625 0 010 5.25H17.25" /></svg>`,
  },
  {
    name: 'Hikari',
    domain: 'hikari.to',
    href: 'https://hikari.to',
    description: 'On-premises fiber network intelligence platform. Hikari automates OTDR fault analysis, delivering root cause analysis with confidence scores to operations teams in minutes instead of hours.',
    focus: ['OTDR Trace Analysis', 'Automated Fault Triage', 'Agentic AI Reasoning', 'On-Premises Deployment', 'Vendor-Agnostic Integration'],
    color: 'purple',
    gradient: 'from-purple to-electric',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  },
  {
    name: 'Axiresearch',
    domain: 'axiresearch.ai',
    href: 'https://axiresearch.ai',
    description: 'AI-powered market intelligence reports delivered in days, not months. Comprehensive, fully cited research powered by multi-agent AI — the depth of a consulting engagement at a fraction of the cost.',
    focus: ['Market Research Reports', 'Competitive Intelligence', 'Due Diligence', 'AI-Powered Analysis', 'Full Source Citations'],
    color: 'orange',
    gradient: 'from-orange-500 to-red-500',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
  },
];
---

<Layout
  title="Our Companies — catdev LLC"
  description="catdev LLC is an engineering-led holding company. We build and operate focused companies across DevSecOps consulting, fiber network intelligence, and AI-powered research."
>
  <section class="pt-32 pb-16 relative">
    <div class="absolute inset-0 hexagon-pattern opacity-20"></div>
    <div class="absolute inset-0 bg-gradient-radial from-electric/5 via-transparent to-transparent"></div>

    <div class="container-custom relative">
      <Breadcrumbs items={[{ label: 'Our Companies' }]} />

      <div class="max-w-3xl mb-16 reveal">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          <span class="text-white">Engineering-led companies</span><br />
          <span class="text-gradient">for hard technical problems</span>
        </h1>
        <p class="text-xl text-steel leading-relaxed mb-4">
          catdev LLC is a holding company based in St. Petersburg, Florida. We build and operate focused companies — each with its own domain expertise, audience, and product.
        </p>
        <p class="text-lg text-steel/80 leading-relaxed">
          What they share: senior engineering teams, an automation-first mindset, and a belief that hard problems deserve dedicated, focused solutions — not one-size-fits-all consulting.
        </p>
      </div>

      <!-- Company Cards -->
      <div class="space-y-8">
        {companies.map((company, index) => (
          <div
            class="card-glass p-8 md:p-10 reveal group hover:-translate-y-1 transition-all duration-300"
            style={`transition-delay: ${index * 100}ms`}
          >
            <div class="glow-effect"></div>
            <div class="relative z-10">
              <div class="flex flex-col lg:flex-row lg:items-start gap-8">
                <!-- Left: Info -->
                <div class="flex-1">
                  <div class="flex items-center gap-4 mb-4">
                    <div class={`inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br ${company.gradient} text-white`}>
                      <div set:html={company.icon} />
                    </div>
                    <div>
                      <h2 class="text-2xl md:text-3xl font-bold text-white">{company.name}</h2>
                      <a
                        href={company.href}
                        target={company.href.startsWith('http') ? '_blank' : undefined}
                        rel={company.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                        class="text-cyan text-sm font-mono hover:text-white transition-colors"
                      >
                        {company.domain}
                      </a>
                    </div>
                  </div>

                  <p class="text-steel leading-relaxed mb-6 max-w-2xl">
                    {company.description}
                  </p>

                  <a
                    href={company.href}
                    target={company.href.startsWith('http') ? '_blank' : undefined}
                    rel={company.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    class="inline-flex items-center text-cyan hover:text-white transition-colors font-semibold"
                  >
                    {company.href.startsWith('http') ? `Visit ${company.name}` : `Explore ${company.name}`}
                    <svg class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                </div>

                <!-- Right: Focus Areas -->
                <div class="lg:w-72 flex-shrink-0">
                  <h3 class="text-xs font-semibold text-white uppercase tracking-wider mb-3">Focus Areas</h3>
                  <div class="flex flex-wrap gap-2">
                    {company.focus.map(area => (
                      <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-steel text-xs">
                        {area}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Philosophy Section -->
      <div class="mt-20 reveal">
        <div class="card-glass p-8 md:p-10">
          <div class="glow-effect"></div>
          <div class="relative z-10 max-w-3xl">
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Why separate companies?</h2>
            <p class="text-steel leading-relaxed mb-4">
              A DevSecOps team evaluating consulting partners has different needs than a fiber operator looking for OTDR automation, or a strategy team commissioning market research. Mixing these under one brand dilutes credibility in each vertical.
            </p>
            <p class="text-steel leading-relaxed">
              Each company stands on its own — with dedicated positioning, domain expertise, and a focused product — while sharing the engineering DNA that comes from building and operating production systems for over a decade.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    headline="Want to work with us?"
    subheadline="Whether you need a platform built, fiber faults analyzed, or a market researched — reach out to the right team."
    primaryCTA={{
      text: 'Contact catdev consulting',
      href: '/contact'
    }}
  />
</Layout>
